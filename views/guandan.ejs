<script>
/*
  掼蛋计分逻辑
  ─────────────────────────────────────────────────
  level: 2-13  = 正常级牌 (2,3,...,K)
         14    = A   (第1关)
         15    = A²  (第2关)
         16    = A³  (第3关)

  点击流程:
  • level < A  → level +1，动画
  • level 升到 A → 显示A，等待下一次点击
  • 在A/A²/A³ 再次点击 → 弹出"过了/不过"窗口

  过了 → 点击方胜局+1，双方level回2，继续比赛
  不过:
    A  → A²
    A² → A³
    A³ → 己方level回2，继续比赛（不算胜负）

  新局开始 → 双方level回2，局数+1，胜局保留
  重置     → 全部归零
  ─────────────────────────────────────────────────
*/
var MAX=14, INIT=2;
var state={
  red:INIT, blue:INIT,
  round:1,
  wins:{red:0, blue:0},
  aReady:{red:false, blue:false}
};

/* ── 标签 ── */
function levelLabel(lv){
  if(lv>=14) return 'A';
  if(lv<=10) return String(lv);
  return {11:'J',12:'Q',13:'K'}[lv];
}
function subLabel(lv){
  if(lv===15) return 'STAGE 2';
  if(lv===16) return 'STAGE 3';
  return '';
}
function badgeLabel(lv){
  if(lv===15) return 'A\u00B2';
  if(lv===16) return 'A\u00B3';
  return '';
}

/* ── 渲染 ── */
function renderPips(t,lv){
  var el=document.getElementById(t+'Pips');
  el.innerHTML='';
  var filled=Math.min(lv,14)-2;
  for(var i=0;i<13;i++){
    var d=document.createElement('div');
    d.className='pip'+(i<filled?' active':'');
    el.appendChild(d);
  }
}
function renderTeam(t){
  var lv=state[t];
  var lbl=levelLabel(lv);
  document.getElementById(t+'CardVal').textContent=lbl;
  document.getElementById(t+'CornerTL').textContent=lbl;
  document.getElementById(t+'CornerBR').textContent=lbl;
  var sub=document.getElementById(t+'CardSub');
  var sl=subLabel(lv);
  sub.textContent=sl;
  sl ? sub.classList.add('show') : sub.classList.remove('show');
  var badge=document.getElementById(t+'ABadge');
  var bl=badgeLabel(lv);
  badge.textContent=bl;
  bl ? badge.classList.add('show') : badge.classList.remove('show');
  document.getElementById(t+'Wins').textContent=state.wins[t];
  renderPips(t,lv);
}
function render(){
  renderTeam('red');
  renderTeam('blue');
  document.getElementById('roundNum').textContent=state.round;
}

/* ── 动画 ── */
function flashCard(t){
  var card=document.getElementById(t+'Card');
  var panel=document.getElementById(t+'Team');
  card.classList.remove('pop');
  panel.classList.remove('flash-'+t);
  void card.offsetWidth;
  card.classList.add('pop');
  panel.classList.add('flash-'+t);
  setTimeout(function(){panel.classList.remove('flash-'+t);},450);
}
function flashWins(t){
  var el=document.getElementById(t+'Wins');
  el.classList.remove('wins-anim');
  void el.offsetWidth;
  el.classList.add('wins-anim');
}

/* ── 点击卡牌区域 ──
   规则：
   · level < A  → +1升级
   · 刚升到A那一次点击 → 只显示A，不弹窗（aReady=true表示下次才弹）
   · 已在A/A²/A³ 且 aReady=true → 弹出判定窗
*/
function onCardClick(t){
  var lv=state[t];
  if(lv < MAX){
    /* 正常升级 */
    state[t]++;
    if(state[t]===MAX){
      /* 刚升到A：显示A，标记下次点击才判定 */
      state.aReady[t]=true;
    }
    flashCard(t);
    render();
    return;
  }
  /* 已在A阶段 */
  if(state.aReady[t]){
    /* 再次点击 → 弹出判定 */
    openAPopup(t);
  }
  /* aReady=false说明刚通过+1按钮到达A，首次点击卡牌才算"再打一次" */
  else{
    state.aReady[t]=true;
  }
}

/* ── ±1 按钮 ── */
function adjustLevel(t, delta){
  var lv=state[t];
  if(delta<0){
    if(lv<=INIT) return;
    state[t]--;
    state.aReady[t]=false;
    flashCard(t); render();
  } else {
    if(lv>=16) return;
    state[t]++;
    if(state[t]>=MAX){
      /* +1按钮升到A：aReady=false，需点卡牌一次才触发判定 */
      state.aReady[t]=false;
    }
    flashCard(t); render();
  }
}

/* ── A阶段弹窗 ── */
var aTeam=null;
function openAPopup(t){
  aTeam=t;
  var lv=state[t];
  var box=document.getElementById('aPopupBox');
  box.className='a-popup '+t;

  var tName=(t==='red')?'红队  RED TEAM':'蓝队  BLUE TEAM';
  document.getElementById('aPopupBadge').textContent=tName;

  var titleMap={14:'A',15:'A\u00B2',16:'A\u00B3'};
  document.getElementById('aPopupTitle').textContent=titleMap[lv]||'A';

  var stageMap={
    14:'第 1 关  STAGE 1',
    15:'第 2 关  STAGE 2',
    16:'第 3 关  STAGE 3'
  };
  document.getElementById('aPopupStage').textContent=stageMap[lv];

  var wName=(t==='red')?'红队':'蓝队';
  var desc='';
  if(lv===14){
    desc='过了：'+wName+'胜局+1，双方回到 2\n不过：升至 A\u00B2，继续比赛';
  } else if(lv===15){
    desc='过了：'+wName+'胜局+1，双方回到 2\n不过：升至 A\u00B3，继续比赛';
  } else {
    desc='过了：'+wName+'胜局+1，双方回到 2\n不过：'+wName+'回到 2，继续比赛';
  }
  document.getElementById('aPopupDesc').innerHTML=desc.replace('\n','<br>');
  document.getElementById('aPopup').classList.add('show');
}

function aResult(passed){
  document.getElementById('aPopup').classList.remove('show');
  var t=aTeam; aTeam=null;
  var lv=state[t];

  if(passed){
    /* 过了 → 点击方胜 */
    recordWin(t);
  } else {
    /* 不过 */
    if(lv===14){
      /* A → A² */
      state[t]=15;
      state.aReady[t]=true;
      flashCard(t); render();
    } else if(lv===15){
      /* A² → A³ */
      state[t]=16;
      state.aReady[t]=true;
      flashCard(t); render();
    } else {
      /* A³ 不过 → 己方回到2，继续比赛，不算胜负 */
      state[t]=INIT;
      state.aReady[t]=false;
      flashCard(t); render();
    }
  }
}

/* ── 记录胜局 ── */
function recordWin(winner){
  state.wins[winner]++;
  flashWins(winner);
  /* 双方level回初始值 */
  state.red=INIT; state.blue=INIT;
  state.aReady={red:false,blue:false};
  render();
  /* 显示胜利弹窗 */
  var box=document.getElementById('winBox');
  box.className='win-box '+winner;
  var zh=(winner==='red')?'红队':'蓝队';
  var en=(winner==='red')?'RED TEAM':'BLUE TEAM';
  document.getElementById('winTitleZH').textContent=zh+' 胜利！';
  document.getElementById('winTitleEN').textContent=en+' WINS!';
  var lv=state[winner]; /* already reset, use wins to show */
  document.getElementById('winSub').innerHTML=
    '恭喜'+zh+'赢得本局！<br>'+
    '红队 '+state.wins.red+' 局  ·  蓝队 '+state.wins.blue+' 局';
  document.getElementById('winOverlay').classList.add('show');
  launchParticles(winner);
}

/* ── 下一局（胜利弹窗里的按钮） ── */
function startNextRound(){
  document.getElementById('winOverlay').classList.remove('show');
  stopParticles();
  state.round++;
  state.red=INIT; state.blue=INIT;
  state.aReady={red:false,blue:false};
  render();
  timerReset(true);
}

/* ── 新局开始（底部按钮） ── */
function newRound(){
  state.round++;
  state.red=INIT; state.blue=INIT;
  state.aReady={red:false,blue:false};
  render();
  ['red','blue'].forEach(function(t){
    var c=document.getElementById(t+'Card');
    c.classList.remove('pop'); void c.offsetWidth; c.classList.add('pop');
  });
  timerReset(true);
}

/* ── 全部重置 ── */
function fullReset(){
  document.getElementById('winOverlay').classList.remove('show');
  stopParticles();
  state={
    red:INIT, blue:INIT,
    round:1,
    wins:{red:0,blue:0},
    aReady:{red:false,blue:false}
  };
  render();
  ['red','blue'].forEach(function(t){
    var c=document.getElementById(t+'Card');
    c.classList.remove('pop'); void c.offsetWidth; c.classList.add('pop');
  });
  timerReset(false);
}

/* ── 计时器 ── */
var timerDefault=60;
var timerSecs=60*60;
var timerInterval=null;
var timerRunning=false;

function timerUpdateDisplay(){
  var m=Math.floor(timerSecs/60);
  var s=timerSecs%60;
  var el=document.getElementById('timerDisplay');
  el.textContent=(m<10?'0':'')+m+':'+(s<10?'0':'')+s;
  el.classList.remove('warning','expired');
  if(timerSecs<=0) el.classList.add('expired');
  else if(timerSecs<=300) el.classList.add('warning');
}

function timerTick(){
  if(timerSecs>0){ timerSecs--; timerUpdateDisplay(); }
  else { timerStop(); }
}

function timerStart(){
  if(timerRunning) return;
  timerRunning=true;
  timerInterval=setInterval(timerTick,1000);
  var btn=document.getElementById('timerToggleBtn');
  btn.textContent='⏸ 暂停';
  btn.classList.add('running');
}

function timerStop(){
  timerRunning=false;
  clearInterval(timerInterval); timerInterval=null;
  var btn=document.getElementById('timerToggleBtn');
  btn.textContent='▶ 开始';
  btn.classList.remove('running');
}

function timerToggle(){
  if(timerRunning) timerStop(); else timerStart();
}

function timerReset(autoStart){
  timerStop();
  timerSecs=timerDefault*60;
  timerUpdateDisplay();
  if(autoStart) timerStart();
}

function timerSetMinutes(val){
  var n=parseInt(val);
  if(isNaN(n)||n<1) n=60;
  if(n>999) n=999;
  timerDefault=n;
  document.getElementById('timerInput').value=n;
  timerReset(false);
}

/* ── 彩带粒子 ── */
var pAnim=null, pArr=[];
function launchParticles(t){
  var canvas=document.getElementById('particles');
  canvas.classList.add('show');
  var ctx=canvas.getContext('2d');
  canvas.width=window.innerWidth;
  canvas.height=window.innerHeight;
  var colors=(t==='red')
    ?['#D10A1E','#FF4D5E','#FFAAAA','#A86800','#FFD700','#FFFFFF']
    :['#0055BB','#3388EE','#88CCFF','#A86800','#FFD700','#FFFFFF'];
  pArr=[];
  for(var i=0;i<150;i++){
    pArr.push({
      x:Math.random()*canvas.width, y:canvas.height+10,
      vx:(Math.random()-0.5)*6, vy:-(Math.random()*11+4),
      r:Math.random()*7+2,
      color:colors[Math.floor(Math.random()*colors.length)],
      alpha:1, rot:Math.random()*360, rotV:(Math.random()-0.5)*10
    });
  }
  function loop(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    pArr.forEach(function(p){
      p.x+=p.vx; p.y+=p.vy; p.vy+=0.13;
      p.rot+=p.rotV; p.alpha-=0.007;
      ctx.save();
      ctx.globalAlpha=Math.max(0,p.alpha);
      ctx.translate(p.x,p.y);
      ctx.rotate(p.rot*Math.PI/180);
      ctx.fillStyle=p.color;
      if(p.r>5){ctx.beginPath();ctx.arc(0,0,p.r/2,0,Math.PI*2);ctx.fill();}
      else{ctx.fillRect(-p.r,-p.r/2,p.r*2,p.r);}
      ctx.restore();
    });
    pArr=pArr.filter(function(p){return p.alpha>0;});
    if(pArr.length>0){pAnim=requestAnimationFrame(loop);}
    else{stopParticles();}
  }
  if(pAnim) cancelAnimationFrame(pAnim);
  pAnim=requestAnimationFrame(loop);
}
function stopParticles(){
  if(pAnim){cancelAnimationFrame(pAnim);pAnim=null;}
  var c=document.getElementById('particles');
  c.classList.remove('show');
  c.getContext('2d').clearRect(0,0,c.width,c.height);
}

render();

// ── 广告模块（服务端渲染版：访问已在服务端记录，广告数据直接注入）───────────────────────
(function(){
  var API = 'https://silicon-guandan-system.onrender.com/scoreboard';

  // 广告数据由服务端直接注入，无需 fetch，无跨域，即时显示
  var allAds = <%- JSON.stringify(ads) %>;
  var normalAds = allAds.filter(function(a){ return !a.frequency_minutes; });
  var specialAds = allAds.filter(function(a){ return !!a.frequency_minutes; });
  var normalIdx = 0;
  var normalTimer = null;
  var adClosed = false;

  if (allAds.length > 0) {
    if (normalAds.length > 0) {
      showNormal(0);
      if (normalAds.length > 1) normalTimer = setTimeout(rotateNormal, 30000);
    } else if (specialAds.length > 0) {
      displayAd(specialAds[0]);
    }
    specialAds.forEach(function(ad) {
      setInterval(function(){
        if (adClosed) return;
        if (normalTimer) { clearTimeout(normalTimer); normalTimer = null; }
        displayAd(ad);
        if (normalAds.length > 0) normalTimer = setTimeout(rotateNormal, 30000);
      }, ad.frequency_minutes * 60 * 1000);
    });
  }

  function showNormal(idx) {
    if (normalAds.length === 0) return;
    normalIdx = idx % normalAds.length;
    displayAd(normalAds[normalIdx]);
  }

  function rotateNormal() {
    if (adClosed) return;
    normalIdx = (normalIdx + 1) % normalAds.length;
    displayAd(normalAds[normalIdx]);
    normalTimer = setTimeout(rotateNormal, 30000);
  }

  function displayAd(ad) {
    var banner = document.getElementById('adBanner');
    var adLink = document.getElementById('adLink');
    var adText = document.getElementById('adText');
    var adImg  = document.getElementById('adImg');

    if (ad.content_type === 'image' && ad.content_url) {
      adImg.src = ad.content_url;
      adImg.style.display = 'block';
      adText.textContent = ad.title;
    } else {
      adText.textContent = ad.content_text || ad.title;
      adImg.style.display = 'none';
    }

    // 重启滚动动画
    adText.style.animation = 'none';
    void adText.offsetWidth;
    adText.style.animation = '';

    adLink.onclick = null;
    if (ad.link_url) {
      adLink.style.cursor = 'pointer';
      adLink.onclick = function(e){
        if (e.target.classList.contains('ad-close')) return;
        trackClick(ad.id);
        window.open(ad.link_url, '_blank', 'noopener');
      };
    } else {
      adLink.style.cursor = 'default';
    }

    banner.style.display = 'block';
    adClosed = false;
    trackImpression(ad.id);
  }

  function trackImpression(id) {
    try { fetch(API + '/api/ads/' + id + '/impression', { method: 'POST' }).catch(function(){}); } catch(e){}
  }

  function trackClick(id) {
    try { fetch(API + '/api/ads/' + id + '/click', { method: 'POST' }).catch(function(){}); } catch(e){}
  }

  window.closeAd = function(e) {
    e.stopPropagation();
    document.getElementById('adBanner').style.display = 'none';
    adClosed = true;
    if (normalTimer) { clearTimeout(normalTimer); normalTimer = null; }
  };
})();
</script>
</body>
</html>