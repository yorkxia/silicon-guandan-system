<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="format-detection" content="telephone=no,email=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
<title>掼蛋计分器 · 硅谷掼蛋协会</title>
<meta name="description" content="硅谷掼蛋协会专用计分器，支持升级计分、胜局记录、每局计时">
<meta property="og:title" content="掼蛋计分器 · 硅谷掼蛋协会">
<meta property="og:description" content="点击即用！升级计分 · 胜局记录 · 每局计时">
<meta property="og:image" content="https://yorkxia.github.io/guandan-scoreboard/Gemini_Generated_Image_logoyork.png">
<meta property="og:url" content="https://yorkxia.github.io/guandan-scoreboard/">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary_large_image">
<script>
(function(){
  function setVH(){document.documentElement.style.setProperty('--vh',(window.innerHeight*0.01)+'px');}
  setVH();
  window.addEventListener('resize',setVH);
})();
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Noto+Serif+SC:wght@400;700;900&family=Oswald:wght@600;700&display=swap" media="print" onload="this.media='all'">
<style>
:root{
  --red:#D10A1E;--red-deep:#8B0000;--red-mid:#C0000F;--red-light:#FF4D5E;--red-border:#E07080;
  --blue:#0055BB;--blue-deep:#003380;--blue-mid:#0044AA;--blue-light:#3388EE;--blue-border:#6699DD;
  --gold:#A86800;--gold-mid:#C8860A;--gold-light:#E8A020;--divider:#B8A890;
}
html{height:100%;}
*{margin:0;padding:0;-webkit-box-sizing:border-box;box-sizing:border-box;-webkit-tap-highlight-color:transparent;-webkit-text-size-adjust:100%;}
body{
  background:-webkit-linear-gradient(135deg,#FDF5E8 0%,#EAF0FC 45%,#FCE8EE 100%);
  background:linear-gradient(150deg,#FDF5E8 0%,#EAF0FC 45%,#FCE8EE 100%);
  min-height:100%;
  font-family:'Noto Serif SC','PingFang SC','Hiragino Sans GB','Microsoft YaHei',serif;
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:center;align-items:center;
  overflow-x:hidden;position:relative;
}
body::before{
  content:'';position:fixed;top:0;right:0;bottom:0;left:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 55% 45% at 8% 55%,rgba(209,10,30,0.09) 0%,transparent 60%),
    radial-gradient(ellipse 55% 45% at 92% 55%,rgba(0,85,187,0.09) 0%,transparent 60%);
}

/* HEADER */
header{
  position:relative;z-index:1;width:100%;max-width:540px;
  display:-webkit-flex;display:flex;
  -webkit-align-items:stretch;align-items:stretch;
  padding:8px 12px 4px;
  gap:10px;
}
.title-wrap{
  -webkit-flex:4;flex:4;
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:flex-start;align-items:flex-start;
  -webkit-justify-content:center;justify-content:center;
  background:-webkit-linear-gradient(150deg,#FFFDF5,#FFF8DC,#FFF0B0);
  background:linear-gradient(150deg,#FFFDF5,#FFF8DC,#FFF0B0);
  border:2.5px solid var(--gold-light);border-radius:20px;
  padding:10px 14px 10px 16px;position:relative;overflow:hidden;
  -webkit-box-shadow:0 8px 28px rgba(168,104,0,0.18),inset 0 1px 0 rgba(255,255,255,0.95);
  box-shadow:0 8px 28px rgba(168,104,0,0.18),inset 0 1px 0 rgba(255,255,255,0.95);
}
.title-wrap::before{
  content:'♠♥♦♣';
  position:absolute;bottom:6px;right:10px;
  font-size:10px;letter-spacing:3px;color:var(--gold-light);opacity:0.7;
}
.title-wrap::after{
  content:'';position:absolute;top:-30px;right:-30px;
  width:100px;height:100px;border-radius:50%;
  background:radial-gradient(circle,rgba(245,200,66,0.12),transparent 70%);
  pointer-events:none;
}
.title-main{
  font-family:'Noto Serif SC','PingFang SC','Microsoft YaHei',serif;
  font-size:19px;font-weight:900;letter-spacing:4px;color:var(--gold);
  text-shadow:0 2px 0 rgba(255,255,255,0.9),0 4px 14px rgba(168,104,0,0.25);
  line-height:1;white-space:nowrap;
}
.title-reg{
  font-size:10px;font-weight:900;vertical-align:super;color:var(--gold-mid);
  font-family:Georgia,serif;margin-left:1px;
}
.title-sub{
  font-family:'Noto Serif SC','PingFang SC',serif;
  font-size:11px;font-weight:700;color:var(--gold-mid);
  margin-top:4px;letter-spacing:3px;opacity:0.90;
}
.title-en{
  font-family:'Oswald','PingFang SC','Microsoft YaHei',sans-serif;
  font-weight:700;font-size:7.5px;letter-spacing:3px;color:var(--gold-mid);margin-top:3px;opacity:0.55;
}

/* ROUND BAR */
.round-bar{
  position:relative;z-index:1;
  display:-webkit-flex;display:flex;
  -webkit-align-items:center;align-items:center;
  margin:8px 0 6px;
  background:rgba(255,255,255,0.85);border:2px solid var(--divider);border-radius:24px;
  padding:5px 22px;
  -webkit-box-shadow:0 3px 12px rgba(0,0,0,0.07);box-shadow:0 3px 12px rgba(0,0,0,0.07);
}
.round-zh{font-size:12px;font-weight:700;color:#666;letter-spacing:2px;margin:0 3px;}
.round-num{font-family:'Playfair Display',Georgia,serif;font-size:20px;font-weight:900;color:var(--gold);line-height:1;margin:0 3px;}
.round-en{font-family:'Oswald','PingFang SC',sans-serif;font-size:10px;font-weight:600;color:#999;letter-spacing:3px;margin-left:6px;}

/* BOARD */
.board{
  position:relative;z-index:1;
  width:100%;max-width:540px;
  display:-ms-grid;display:grid;
  grid-template-columns:1fr 46px 1fr;
  padding:0 10px;
}

/* TEAM PANEL */
.team{
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:center;align-items:center;
  padding:0 6px 14px;border-radius:28px;
  position:relative;overflow:hidden;cursor:pointer;
  -webkit-user-select:none;user-select:none;
  -webkit-transition:-webkit-transform 0.12s,box-shadow 0.15s;
  transition:transform 0.12s,box-shadow 0.15s;
}
.team:active{-webkit-transform:scale(0.972);transform:scale(0.972);}
.team.red{
  background:-webkit-linear-gradient(top,#FFF3F4 0%,#FFE4E7 55%,#FFD8DC 100%);
  background:linear-gradient(175deg,#FFF3F4 0%,#FFE4E7 55%,#FFD8DC 100%);
  border:3px solid var(--red-border);
  -webkit-box-shadow:0 10px 36px rgba(209,10,30,0.16),inset 0 1px 0 rgba(255,255,255,0.96);
  box-shadow:0 10px 36px rgba(209,10,30,0.16),inset 0 1px 0 rgba(255,255,255,0.96);
}
.team.blue{
  background:-webkit-linear-gradient(top,#EEF6FF 0%,#DCE9FF 55%,#D0E2FF 100%);
  background:linear-gradient(175deg,#EEF6FF 0%,#DCE9FF 55%,#D0E2FF 100%);
  border:3px solid var(--blue-border);
  -webkit-box-shadow:0 10px 36px rgba(0,85,187,0.16),inset 0 1px 0 rgba(255,255,255,0.96);
  box-shadow:0 10px 36px rgba(0,85,187,0.16),inset 0 1px 0 rgba(255,255,255,0.96);
}
.team-header{
  width:100%;padding:11px 8px 9px;
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:center;align-items:center;
  border-radius:25px 25px 0 0;margin-bottom:8px;
}
.team.red .team-header{background:-webkit-linear-gradient(135deg,#E8001A,#7A0000);background:linear-gradient(135deg,#E8001A,#7A0000);}
.team.blue .team-header{background:-webkit-linear-gradient(135deg,#0044BB,#002277);background:linear-gradient(135deg,#0044BB,#002277);}
.team-name{font-size:22px;font-weight:900;letter-spacing:6px;color:#FFF;text-shadow:0 1px 4px rgba(0,0,0,0.35);line-height:1.1;}
.team-name-en{font-family:'Oswald','PingFang SC',sans-serif;font-weight:700;font-size:10px;letter-spacing:4px;color:rgba(255,255,255,0.65);margin-top:2px;}

/* CARD */
.card-display{
  width:90%;height:200px;
  border-radius:22px;
  display:-webkit-flex;display:flex;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;
  margin-bottom:10px;position:relative;
  -webkit-transition:-webkit-transform 0.3s cubic-bezier(0.175,0.885,0.32,1.275);
  transition:transform 0.3s cubic-bezier(0.175,0.885,0.32,1.275);
  background:#FFFFFF;
}
.team.red .card-display{
  border:3px solid var(--red-border);
  -webkit-box-shadow:0 10px 32px rgba(209,10,30,0.22),inset 0 1px 0 #FFF;
  box-shadow:0 10px 32px rgba(209,10,30,0.22),inset 0 1px 0 #FFF;
}
.team.blue .card-display{
  border:3px solid var(--blue-border);
  -webkit-box-shadow:0 10px 32px rgba(0,85,187,0.22),inset 0 1px 0 #FFF;
  box-shadow:0 10px 32px rgba(0,85,187,0.22),inset 0 1px 0 #FFF;
}
.card-display::before{
  content:'';position:absolute;top:7px;right:7px;bottom:7px;left:7px;
  border-radius:16px;opacity:0.04;
}
.team.red .card-display::before{background:repeating-linear-gradient(45deg,var(--red) 0,var(--red) 1px,transparent 1px,transparent 8px);}
.team.blue .card-display::before{background:repeating-linear-gradient(45deg,var(--blue) 0,var(--blue) 1px,transparent 1px,transparent 8px);}
.card-value-wrap{
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:center;align-items:center;
  z-index:1;position:relative;
}
.card-value{
  font-family:'Playfair Display',Georgia,serif;
  font-size:110px;font-weight:900;line-height:0.85;
  -webkit-transition:all 0.25s;transition:all 0.25s;text-align:center;
}
.team.red .card-value{color:var(--red);text-shadow:0 4px 20px rgba(209,10,30,0.38);}
.team.blue .card-value{color:var(--blue);text-shadow:0 4px 20px rgba(0,85,187,0.38);}
.card-sub{
  font-family:'Oswald','PingFang SC',sans-serif;font-weight:700;
  font-size:14px;letter-spacing:3px;margin-top:2px;opacity:0;
  -webkit-transition:opacity 0.25s;transition:opacity 0.25s;
}
.card-sub.show{opacity:1;}
.team.red .card-sub{color:var(--red-mid);}
.team.blue .card-sub{color:var(--blue-mid);}
.card-corner{
  position:absolute;font-family:'Playfair Display',Georgia,serif;
  font-size:14px;font-weight:900;line-height:1;z-index:2;
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:center;align-items:center;
}
.card-corner.tl{top:9px;left:11px;}
.card-corner.br{bottom:9px;right:11px;-webkit-transform:rotate(180deg);transform:rotate(180deg);}
.team.red .card-corner{color:var(--red);}
.team.blue .card-corner{color:var(--blue);}
.card-corner .suit{font-size:10px;}
.card-center-suit{position:absolute;font-size:24px;opacity:0.06;bottom:14px;left:50%;-webkit-transform:translateX(-50%);transform:translateX(-50%);z-index:1;}
.team.red .card-center-suit{color:var(--red);}
.team.blue .card-center-suit{color:var(--blue);}
.a-badge{
  position:absolute;top:8px;right:8px;z-index:3;
  background:-webkit-linear-gradient(135deg,var(--gold-light),var(--gold));
  background:linear-gradient(135deg,var(--gold-light),var(--gold));
  color:#FFF;font-family:'Oswald','PingFang SC',sans-serif;
  font-size:12px;font-weight:700;letter-spacing:1px;
  padding:4px 9px;border-radius:20px;opacity:0;
  -webkit-transition:opacity 0.3s;transition:opacity 0.3s;
  -webkit-box-shadow:0 2px 10px rgba(168,104,0,0.50);box-shadow:0 2px 10px rgba(168,104,0,0.50);
}
.a-badge.show{opacity:1;}

/* WINS */
.wins-block{
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:center;align-items:center;
  margin-top:6px;
}
.wins-block>*+*{margin-top:2px;}
.wins-num{
  font-family:'Playfair Display',Georgia,serif;
  font-size:38px;font-weight:900;line-height:1;
  -webkit-transition:all 0.3s cubic-bezier(0.175,0.885,0.32,1.275);
  transition:all 0.3s cubic-bezier(0.175,0.885,0.32,1.275);
}
.team.red .wins-num{color:var(--red);text-shadow:0 2px 10px rgba(209,10,30,0.32);}
.team.blue .wins-num{color:var(--blue);text-shadow:0 2px 10px rgba(0,85,187,0.32);}
.wins-zh{font-size:10px;font-weight:700;letter-spacing:3px;}
.team.red .wins-zh{color:var(--red-mid);}
.team.blue .wins-zh{color:var(--blue-mid);}
.wins-en{font-family:'Oswald','PingFang SC',sans-serif;font-size:8px;font-weight:600;letter-spacing:3px;opacity:0.55;}
.team.red .wins-en{color:var(--red);}
.team.blue .wins-en{color:var(--blue);}

/* PIPS */
.pips{
  display:-webkit-flex;display:flex;
  -webkit-flex-wrap:wrap;flex-wrap:wrap;
  -webkit-justify-content:center;justify-content:center;
  margin-top:8px;max-width:120px;
}
.pip{width:9px;height:9px;border-radius:50%;margin:3px;-webkit-transition:all 0.3s;transition:all 0.3s;}
.team.red .pip{background:rgba(209,10,30,0.10);border:2px solid rgba(209,10,30,0.22);}
.team.red .pip.active{background:var(--red);border-color:var(--red-deep);-webkit-box-shadow:0 0 8px rgba(209,10,30,0.55);box-shadow:0 0 8px rgba(209,10,30,0.55);-webkit-transform:scale(1.2);transform:scale(1.2);}
.team.blue .pip{background:rgba(0,85,187,0.10);border:2px solid rgba(0,85,187,0.22);}
.team.blue .pip.active{background:var(--blue);border-color:var(--blue-deep);-webkit-box-shadow:0 0 8px rgba(0,85,187,0.55);box-shadow:0 0 8px rgba(0,85,187,0.55);-webkit-transform:scale(1.2);transform:scale(1.2);}

/* DIVIDER */
.divider{
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;
  padding:8px 0;position:relative;z-index:2;
}
.divider>*+*{margin-top:6px;}
.divider-line{width:2px;-webkit-flex:1;flex:1;background:-webkit-linear-gradient(top,transparent,var(--divider),transparent);background:linear-gradient(to bottom,transparent,var(--divider),transparent);}
.vs-badge{
  width:40px;height:40px;border-radius:50%;
  background:-webkit-linear-gradient(145deg,#FFFDF0,#FFF8D0);
  background:linear-gradient(145deg,#FFFDF0,#FFF8D0);
  border:2.5px solid var(--gold-light);
  display:-webkit-flex;display:flex;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;
  font-family:'Oswald','PingFang SC',sans-serif;font-size:11px;font-weight:700;color:var(--gold);letter-spacing:1px;
  -webkit-box-shadow:0 4px 16px rgba(168,104,0,0.25);box-shadow:0 4px 16px rgba(168,104,0,0.25);
}

/* CONTROLS */
.controls{
  position:relative;z-index:1;width:100%;max-width:540px;padding:10px 10px 6px;
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
}
.controls>*+*{margin-top:8px;}
.btn-row{display:-webkit-flex;display:flex;}
.btn-row>*+*{margin-left:7px;}
.btn{
  -webkit-flex:1;flex:1;border:none;border-radius:18px;padding:0 4px;height:52px;
  font-family:'Noto Serif SC','PingFang SC',serif;font-weight:900;cursor:pointer;
  -webkit-transition:-webkit-transform 0.14s,opacity 0.14s;transition:transform 0.14s,opacity 0.14s;
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;
}
.btn:active{-webkit-transform:scale(0.93);transform:scale(0.93);}
.btn .btn-zh{font-size:13px;font-weight:900;letter-spacing:1px;line-height:1;}
.btn .btn-en{font-family:'Oswald','PingFang SC',sans-serif;font-size:8px;font-weight:600;letter-spacing:2px;opacity:0.75;}
.btn-red-plus{background:-webkit-linear-gradient(145deg,#FF2D40,#8B0000);background:linear-gradient(145deg,#FF2D40,#8B0000);color:#FFF;-webkit-box-shadow:0 5px 18px rgba(209,10,30,0.42);box-shadow:0 5px 18px rgba(209,10,30,0.42);border:1.5px solid rgba(255,255,255,0.15);}
.btn-red-minus{background:-webkit-linear-gradient(145deg,#FFE8EA,#FFCDD2);background:linear-gradient(145deg,#FFE8EA,#FFCDD2);color:var(--red-deep);border:2px solid var(--red-border);}
.btn-blue-plus{background:-webkit-linear-gradient(145deg,#1A6AFF,#002277);background:linear-gradient(145deg,#1A6AFF,#002277);color:#FFF;-webkit-box-shadow:0 5px 18px rgba(0,85,187,0.42);box-shadow:0 5px 18px rgba(0,85,187,0.42);border:1.5px solid rgba(255,255,255,0.15);}
.btn-blue-minus{background:-webkit-linear-gradient(145deg,#DDE8FF,#C8D8FF);background:linear-gradient(145deg,#DDE8FF,#C8D8FF);color:var(--blue-deep);border:2px solid var(--blue-border);}
.btn-reset{
  -webkit-flex:none;flex:none;width:64px;height:52px;
  background:-webkit-linear-gradient(145deg,#F5F0E0,#EAE0C8);background:linear-gradient(145deg,#F5F0E0,#EAE0C8);
  border:2px solid var(--divider);color:#6A5C40;
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;
  border-radius:18px;cursor:pointer;
  -webkit-transition:-webkit-transform 0.14s;transition:transform 0.14s;
}
.btn-reset:active{-webkit-transform:scale(0.93);transform:scale(0.93);}
.btn-reset .btn-zh{font-family:'Noto Serif SC','PingFang SC',serif;font-size:12px;font-weight:900;letter-spacing:1px;}
.btn-reset .btn-en{font-family:'Oswald','PingFang SC',sans-serif;font-size:7px;font-weight:600;letter-spacing:2px;opacity:0.6;}
.btn-new-round{
  width:100%;height:50px;
  background:-webkit-linear-gradient(145deg,#F0B020,#A86800);background:linear-gradient(145deg,#F0B020,#A86800);
  border:2px solid rgba(255,255,255,0.22);color:#FFF;
  border-radius:18px;cursor:pointer;
  -webkit-transition:-webkit-transform 0.14s;transition:transform 0.14s;
  display:-webkit-flex;display:flex;
  -webkit-flex-direction:column;flex-direction:column;
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;
  -webkit-box-shadow:0 6px 22px rgba(168,104,0,0.40);box-shadow:0 6px 22px rgba(168,104,0,0.40);
  text-shadow:0 1px 3px rgba(0,0,0,0.15);
}
.btn-new-round:active{-webkit-transform:scale(0.96);transform:scale(0.96);}
.btn-new-round .btn-zh{font-family:'Noto Serif SC','PingFang SC',serif;font-size:15px;font-weight:900;letter-spacing:5px;line-height:1;}
.btn-new-round .btn-en{font-family:'Oswald','PingFang SC',sans-serif;font-size:8px;font-weight:600;letter-spacing:4px;opacity:0.80;}
.hint{text-align:center;font-size:10px;font-weight:700;color:#9A8870;letter-spacing:2px;padding:4px 0 8px;position:relative;z-index:1;}

/* A-STAGE POPUP */
.a-popup-overlay{
  display:none;position:fixed;top:0;right:0;bottom:0;left:0;z-index:200;
  background:rgba(238,224,198,0.97);
  -webkit-align-items:center;align-items:center;
  -webkit-justify-content:center;justify-content:center;
}
.a-popup-overlay.show{display:-webkit-flex;display:flex;}
.a-popup{
  border-radius:28px;padding:30px 28px 26px;text-align:center;
  min-width:260px;max-width:310px;
  -webkit-box-shadow:0 20px 60px rgba(0,0,0,0.22);box-shadow:0 20px 60px rgba(0,0,0,0.22);
  -webkit-animation:popIn 0.3s cubic-bezier(0.175,0.885,0.32,1.275);animation:popIn 0.3s cubic-bezier(0.175,0.885,0.32,1.275);
}
.a-popup.red{background:-webkit-linear-gradient(145deg,#FFF0F1,#FFE0E4);background:linear-gradient(145deg,#FFF0F1,#FFE0E4);border:3px solid var(--red-border);}
.a-popup.blue{background:-webkit-linear-gradient(145deg,#EEF5FF,#DDEEFF);background:linear-gradient(145deg,#EEF5FF,#DDEEFF);border:3px solid var(--blue-border);}
.a-popup-badge{
  display:inline-block;padding:4px 16px;border-radius:20px;margin-bottom:12px;
  font-family:'Oswald','PingFang SC',sans-serif;font-size:11px;font-weight:700;letter-spacing:3px;color:#FFF;
}
