/* ANIMATIONS */
@-webkit-keyframes flashRed{
  0%,100%{-webkit-box-shadow:0 10px 36px rgba(209,10,30,0.16),inset 0 1px 0 rgba(255,255,255,0.96);}
  40%{-webkit-box-shadow:0 12px 52px rgba(209,10,30,0.55),inset 0 1px 0 rgba(255,255,255,0.96);}
}
@keyframes flashRed{
  0%,100%{box-shadow:0 10px 36px rgba(209,10,30,0.16),inset 0 1px 0 rgba(255,255,255,0.96);}
  40%{box-shadow:0 12px 52px rgba(209,10,30,0.55),inset 0 1px 0 rgba(255,255,255,0.96);}
}
@-webkit-keyframes flashBlue{
  0%,100%{-webkit-box-shadow:0 10px 36px rgba(0,85,187,0.16),inset 0 1px 0 rgba(255,255,255,0.96);}
  40%{-webkit-box-shadow:0 12px 52px rgba(0,85,187,0.55),inset 0 1px 0 rgba(255,255,255,0.96);}
}
@keyframes flashBlue{
  0%,100%{box-shadow:0 10px 36px rgba(0,85,187,0.16),inset 0 1px 0 rgba(255,255,255,0.96);}
  40%{box-shadow:0 12px 52px rgba(0,85,187,0.55),inset 0 1px 0 rgba(255,255,255,0.96);}
}
@-webkit-keyframes popIn{0%{-webkit-transform:scale(0.75);opacity:0.5;}65%{-webkit-transform:scale(1.06);}100%{-webkit-transform:scale(1);opacity:1;}}
@keyframes popIn{0%{transform:scale(0.75);opacity:0.5;}65%{transform:scale(1.06);}100%{transform:scale(1);opacity:1;}}
@-webkit-keyframes winsUp{0%{-webkit-transform:scale(0.5) translateY(8px);opacity:0;}100%{-webkit-transform:scale(1) translateY(0);opacity:1;}}
@keyframes winsUp{0%{transform:scale(0.5) translateY(8px);opacity:0;}100%{transform:scale(1) translateY(0);opacity:1;}}
.flash-red{-webkit-animation:flashRed 0.45s ease;animation:flashRed 0.45s ease;}
.flash-blue{-webkit-animation:flashBlue 0.45s ease;animation:flashBlue 0.45s ease;}
.pop{-webkit-animation:popIn 0.32s cubic-bezier(0.175,0.885,0.32,1.275);animation:popIn 0.32s cubic-bezier(0.175,0.885,0.32,1.275);}
.wins-anim{-webkit-animation:winsUp 0.4s cubic-bezier(0.175,0.885,0.32,1.275);animation:winsUp 0.4s cubic-bezier(0.175,0.885,0.32,1.275);}
