<style>
    .a-main {
      background: linear-gradient(165deg, #E8F0FA 0%, #F8EFE0 48%, #EEF5FF 100%) !important;
      min-height: 100vh;
    }

    /* ── 顶部标题区 ── */
    .gd6-header {
      display: flex;
      align-items: center;
      gap: 18px;
      margin-bottom: 32px;
      padding-bottom: 20px;
      border-bottom: 2px solid rgba(0,85,187,0.12);
    }
    .gd6-header-logo {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      border: 2px solid #6699DD;
      object-fit: cover;
      box-shadow: 0 4px 14px rgba(0,85,187,0.2);
    }
    .gd6-header-text h1 {
      font-size: 1.45rem;
      font-weight: 900;
      color: #003380;
      letter-spacing: 2px;
      margin: 0 0 4px;
    }
    .gd6-header-text p {
      font-size: 0.8rem;
      color: #888;
      letter-spacing: 3px;
      margin: 0;
    }
    .gd6-back {
      margin-left: auto;
      padding: 7px 18px;
      border-radius: 8px;
      background: rgba(0,85,187,0.08);
      color: #0055BB;
      border: 1px solid rgba(0,85,187,0.25);
      font-size: 0.82rem;
      text-decoration: none;
      transition: all 0.2s;
      white-space: nowrap;
    }
    .gd6-back:hover {
      background: rgba(0,85,187,0.15);
      text-decoration: none;
      color: #003380;
    }

    /* ── 三张选项卡 ── */
    .gd6-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      max-width: 960px;
    }

    .gd6-card {
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 6px 28px rgba(0,0,0,0.10);
      background: #fff;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      cursor: pointer;
    }
    .gd6-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 18px 48px rgba(0,0,0,0.16);
      text-decoration: none;
      color: inherit;
    }

    /* 每张卡的顶部色带 */
    .gd6-card-head {
      padding: 26px 20px 18px;
      position: relative;
      overflow: hidden;
      text-align: center;
    }
    .gd6-card-head::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
    }

    /* 卡1：个人随机 — 橙金暖色 */
    .gd6-card-1 .gd6-card-head {
      background: linear-gradient(145deg, #FFF8E8 0%, #FFF0CC 100%);
      border-bottom: 3px solid #E8A020;
    }
    .gd6-card-1 .gd6-icon-bg {
      background: linear-gradient(135deg, #E8A020, #A86800);
      box-shadow: 0 6px 20px rgba(232,160,32,0.4);
    }
    .gd6-card-1 .gd6-mode-num { color: #A86800; }
    .gd6-card-1 .gd6-mode-title { color: #7A4A00; }
    .gd6-card-1 .gd6-tag { background: #FFF0CC; color: #A86800; border-color: #E8C060; }
    .gd6-card-1 .gd6-btn {
      background: linear-gradient(135deg, #E8A020, #A86800);
      box-shadow: 0 4px 14px rgba(232,160,32,0.4);
    }
    .gd6-card-1 .gd6-btn:hover { background: linear-gradient(135deg, #F5B030, #C8860A); }

    /* 卡2：亲友开房 — 青绿暖色 */
    .gd6-card-2 .gd6-card-head {
      background: linear-gradient(145deg, #F0FBF5 0%, #DCF5E8 100%);
      border-bottom: 3px solid #27AE60;
    }
    .gd6-card-2 .gd6-icon-bg {
      background: linear-gradient(135deg, #27AE60, #1A7A40);
      box-shadow: 0 6px 20px rgba(39,174,96,0.4);
    }
    .gd6-card-2 .gd6-mode-num { color: #1A7A40; }
    .gd6-card-2 .gd6-mode-title { color: #155A30; }
    .gd6-card-2 .gd6-tag { background: #DCF5E8; color: #1A7A40; border-color: #80D4A8; }
    .gd6-card-2 .gd6-btn {
      background: linear-gradient(135deg, #27AE60, #1A7A40);
      box-shadow: 0 4px 14px rgba(39,174,96,0.4);
    }
    .gd6-card-2 .gd6-btn:hover { background: linear-gradient(135deg, #2ECC71, #219A52); }

    /* 卡3：大型比赛 — 蓝紫高端 */
    .gd6-card-3 .gd6-card-head {
      background: linear-gradient(145deg, #F0EEFF 0%, #E0D8FF 100%);
      border-bottom: 3px solid #6C3EBB;
    }
    .gd6-card-3 .gd6-icon-bg {
      background: linear-gradient(135deg, #7B52D4, #4A2290);
      box-shadow: 0 6px 20px rgba(123,82,212,0.4);
    }
    .gd6-card-3 .gd6-mode-num { color: #6C3EBB; }
    .gd6-card-3 .gd6-mode-title { color: #3D1E80; }
    .gd6-card-3 .gd6-tag { background: #E0D8FF; color: #6C3EBB; border-color: #B09CE0; }
    .gd6-card-3 .gd6-btn {
      background: linear-gradient(135deg, #7B52D4, #4A2290);
      box-shadow: 0 4px 14px rgba(123,82,212,0.4);
    }
    .gd6-card-3 .gd6-btn:hover { background: linear-gradient(135deg, #9066E8, #5A30A8); }

    /* 通用头部内容 */
    .gd6-icon-bg {
      width: 64px;
      height: 64px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      margin: 0 auto 14px;
    }
    .gd6-mode-num {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 3px;
      margin-bottom: 6px;
    }
    .gd6-mode-title {
      font-size: 1.2rem;
      font-weight: 900;
      letter-spacing: 3px;
      line-height: 1.3;
    }

    /* 卡片主体 */
    .gd6-card-body {
      padding: 18px 20px 22px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .gd6-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-bottom: 14px;
      justify-content: center;
    }
    .gd6-tag {
      padding: 3px 10px;
      border-radius: 14px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 1px;
      border: 1px solid;
    }
    .gd6-desc {
      font-size: 0.82rem;
      color: #666;
      line-height: 1.85;
      text-align: center;
      flex: 1;
      margin-bottom: 18px;
    }
    .gd6-btn {
      display: block;
      width: 100%;
      padding: 12px 0;
      border-radius: 10px;
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-align: center;
      color: #fff;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.25s ease;
    }
    .gd6-btn:hover {
      transform: translateY(-2px);
      color: #fff;
      text-decoration: none;
    }

    /* 小提示 */
    .gd6-hint {
      max-width: 960px;
      margin-top: 28px;
      padding: 14px 20px;
      background: rgba(0,85,187,0.06);
      border-radius: 10px;
      border-left: 4px solid #6699DD;
      font-size: 0.82rem;
      color: #555;
      line-height: 1.8;
    }

    @media (max-width: 860px) {
      .gd6-grid { grid-template-columns: 1fr; max-width: 440px; }
      .gd6-header { flex-wrap: wrap; }
    }
</style>

<!-- 顶部标题 -->
<div class="gd6-header">
  <img src="/img/assoc-logo.png" alt="会徽" class="gd6-header-logo">
  <div class="gd6-header-text">
    <h1>🎴 六人掼蛋赛事 · 选择模式</h1>
    <p>Silicon Valley Guandan Association · 6-Player Tournaments</p>
  </div>
  <a href="<%= locals.otBase || '/admin' %>/tournaments-online" class="gd6-back">← 返回赛事首页</a>
</div>

<div class="gd6-grid">

  <!-- 1. 个人随机参赛 -->
  <a href="#" class="gd6-card gd6-card-1" onclick="return false;">
    <div class="gd6-card-head">
      <div class="gd6-icon-bg">🎲</div>
      <div class="gd6-mode-num">模式 01 · MODE 01</div>
      <div class="gd6-mode-title">个人随机参赛</div>
    </div>
    <div class="gd6-card-body">
      <div class="gd6-tags">
        <span class="gd6-tag">🎲 随机匹配</span>
