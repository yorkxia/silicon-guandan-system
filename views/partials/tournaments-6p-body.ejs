<script src="/socket.io/socket.io.js"></script>
<script src="/js/gd-socket.js"></script>
<script>
var GD_MODE = '6p';
var qTimer = null, qSec = 0;
var spinners = ['⏳','🔄','⚡','🎲'];
var gdRoomAction = null;
var gdInviteCode = null;
var gdInviteUrl  = null;

function openQueue() {
  document.getElementById('overlay-queue').style.display = 'flex';
  qSec = 0;
  document.getElementById('q-timer').textContent = '0';
  qTimer = setInterval(function(){
    qSec++;
    document.getElementById('q-timer').textContent = qSec;
    document.getElementById('q-spinner').textContent = spinners[qSec % spinners.length];
  }, 1000);
  function tryJoin() {
    if (window.gdSocket && window.gdSocket.connected) {
      window.gdSocket.emit('queue:join', { token: window.gdGetToken(), name: window.gdGetName(), mode: GD_MODE });
    } else { setTimeout(tryJoin, 300); }
  }
  tryJoin();
}
function cancelQueue() {
  clearInterval(qTimer);
  document.getElementById('overlay-queue').style.display = 'none';
  if (window.gdSocket) window.gdSocket.emit('queue:cancel', { token: window.gdGetToken() });
}
function openRoom() { document.getElementById('overlay-room').style.display = 'flex'; }
function closeRoom() { document.getElementById('overlay-room').style.display = 'none'; }

function doCreateRoom() {
  gdRoomAction = 'create';
  setRoomMsg('创建中...');
  function tryCreate() {
    if (window.gdSocket && window.gdSocket.connected) {
      window.gdSocket.emit('room:create', { token: window.gdGetToken(), name: window.gdGetName(), mode: GD_MODE });
    } else { setTimeout(tryCreate, 300); }
  }
  tryCreate();
}
function doJoinRoom() {
  var code = document.getElementById('room-code-input').value.trim().toUpperCase();
  if (code.length < 4) return setRoomMsg('请输入正确的房间号');
  gdRoomAction = 'join';
  if (window.gdSocket && window.gdSocket.connected) {
    window.gdSocket.emit('room:join', { token: window.gdGetToken(), name: window.gdGetName(), roomCode: code });
  } else { setRoomMsg('连接中，请稍候重试'); }
}
function setRoomMsg(msg) { document.getElementById('room-msg').textContent = msg; }

function showInviteOverlay(roomCode) {
  closeRoom();
  gdInviteCode = roomCode;
  var host    = window.location.host;
  var proto   = window.location.protocol;
  gdInviteUrl = proto + '//' + host + '/play/join?code=' + roomCode;

  document.getElementById('invite-code-display').textContent = roomCode;
  document.getElementById('invite-qr-img').src = '/play/qr?code=' + roomCode;
  document.getElementById('invite-qr-url').textContent = gdInviteUrl;
  document.getElementById('overlay-invite').style.display = 'flex';
}

function copyRoomCode() {
  navigator.clipboard.writeText(gdInviteCode || '').then(function() {
    var btn = document.getElementById('copy-code-btn');
    btn.textContent = '✅ 已复制';
    setTimeout(function(){ btn.textContent = '📋 复制'; }, 2000);
  }).catch(function() {
    var el = document.getElementById('invite-code-display');
    var r = document.createRange(); r.selectNode(el);
    window.getSelection().removeAllRanges(); window.getSelection().addRange(r);
  });
}

function copyInviteLink() {
  var text = '我在硅谷掼蛋联赛开了一桌六人掼蛋，房间号：' + gdInviteCode +
             '\n扫码或点击链接直接加入：' + gdInviteUrl;
  navigator.clipboard.writeText(text).then(function() {
    var btn = document.getElementById('copy-link-btn');
    btn.textContent = '✅ 邀请链接已复制！';
    setTimeout(function(){ btn.textContent = '🔗 复制邀请链接（含二维码）'; }, 2500);
  });
}

function doReady() {
  if (!gdInviteCode) return;
  document.getElementById('ready-btn').textContent = '正在进入...';
  document.getElementById('ready-btn').disabled = true;
  location.href = '/play/game/' + gdInviteCode;
}

function initScanJoin() {
  var params = new URLSearchParams(window.location.search);
  var joinCode = params.get('join');
  if (!joinCode) return;
  joinCode = joinCode.toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 6);
  if (!joinCode) return;
  document.getElementById('scan-join-code').textContent = joinCode;
  document.getElementById('overlay-scan-join').style.display = 'flex';
  document.getElementById('room-code-input').value = joinCode;
  window._scanJoinCode = joinCode;
}

function doScanJoin() {
  var code = window._scanJoinCode;
  if (!code) return;
  document.getElementById('scan-join-btn').textContent = '加入中...';
  document.getElementById('scan-join-btn').disabled = true;
  gdRoomAction = 'join';
  function tryJoin() {
    if (window.gdSocket && window.gdSocket.connected) {
      window.gdSocket.emit('room:join', { token: window.gdGetToken(), name: window.gdGetName(), roomCode: code });
    } else { setTimeout(tryJoin, 300); }
  }
  tryJoin();
}

document.addEventListener('DOMContentLoaded', function() {
  initScanJoin();

  function attachEvents() {
    if (!window.gdSocket) { setTimeout(attachEvents, 300); return; }

    window.gdSocket.on('queue:joined', function(d) {
      clearInterval(qTimer);
      document.getElementById('q-msg').textContent = '✅ 已进入房间，跳转中...';
      setTimeout(function(){ location.href = '/play/game/' + d.roomCode; }, 400);
    });
    window.gdSocket.on('queue:error', function(d) {
      clearInterval(qTimer);
      document.getElementById('q-msg').textContent = '❌ ' + d.message;
    });

    window.gdSocket.on('room:joined', function(d) {
      document.getElementById('overlay-scan-join').style.display = 'none';
      if (gdRoomAction === 'create') {
        showInviteOverlay(d.roomCode);
      } else {
        location.href = '/play/game/' + d.roomCode;
      }
    });
    window.gdSocket.on('room:error', function(d) {
      document.getElementById('scan-join-btn') && (document.getElementById('scan-join-btn').disabled = false);
      document.getElementById('scan-join-btn') && (document.getElementById('scan-join-btn').textContent = '立即加入游戏');
      setRoomMsg('❌ ' + d.message);
    });
  }
  attachEvents();
});
</script>
