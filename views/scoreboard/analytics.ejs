<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>流量统计 | Analytics</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/scoreboard-admin.css">
</head>
<body>
<% const activePage = 'analytics'; %>
<div class="sb-wrap">
  <%- include('_layout', { activePage }) %>

  <main class="sb-main">
    <div class="sb-page-head">
      <h1>📈 流量统计 · Analytics</h1>
      <form action="/scoreboard/analytics" method="GET" style="display:flex; align-items:center; gap:12px; flex-wrap:wrap">
        <label style="color:#ccc; font-size:0.85rem">来源：</label>
        <select name="source" class="a-input" style="width:auto; padding:6px 12px" onchange="this.form.submit()">
          <option value="all"     <%= source === 'all'     ? 'selected' : '' %>>全部来源</option>
          <option value="guandan" <%= source === 'guandan' ? 'selected' : '' %>>掼蛋计分器</option>
          <option value="gs"      <%= source === 'gs'      ? 'selected' : '' %>>赛事系统</option>
        </select>
        <label style="color:#ccc; font-size:0.85rem">时间范围：</label>
        <select name="days" class="a-input" style="width:auto; padding:6px 12px" onchange="this.form.submit()">
          <option value="7" <%= days === 7 ? 'selected' : '' %>>近7天</option>
          <option value="30" <%= days === 30 ? 'selected' : '' %>>近30天</option>
          <option value="90" <%= days === 90 ? 'selected' : '' %>>近90天</option>
          <option value="365" <%= days === 365 ? 'selected' : '' %>>近1年</option>
        </select>
      </form>
    </div>

    <!-- Total -->
    <div class="stats-row">
      <div class="stat-box">
        <div class="stat-num"><%= total ? total.cnt : 0 %></div>
        <div class="stat-lbl">总访问量 · Total Visits (<%= days %>天)</div>
      </div>
      <div class="stat-box">
        <div class="stat-num"><%= byRegion ? byRegion.length : 0 %></div>
        <div class="stat-lbl">活跃区域数 · Active Regions</div>
      </div>
      <div class="stat-box">
        <div class="stat-num"><%= byCountry ? byCountry.length : 0 %></div>
        <div class="stat-lbl">访问国家数 · Countries</div>
      </div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:20px">
      <!-- By Region -->
      <div class="a-card">
        <h3 style="margin:0 0 16px; color:#D4AC0D">📍 按区域统计</h3>
        <% if (byRegion && byRegion.length > 0) { %>
          <%
            const maxRegion = Math.max(...byRegion.map(r => parseInt(r.cnt)));
          %>
          <% byRegion.forEach(function(r) { %>
            <div style="margin-bottom:10px">
              <div style="display:flex; justify-content:space-between; margin-bottom:3px">
                <span style="color:#ccc; font-size:0.85rem"><%= r.region_code %></span>
                <strong style="color:#D4AC0D"><%= r.cnt %></strong>
              </div>
              <div style="background:#222; border-radius:4px; height:8px; overflow:hidden">
                <div style="background:linear-gradient(90deg,#D4AC0D,#F0C820); height:100%; width:<%= Math.round(parseInt(r.cnt)/maxRegion*100) %>%; border-radius:4px; transition:width 0.3s"></div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <p style="color:#666">暂无数据</p>
        <% } %>
      </div>

      <!-- By Country -->
      <div class="a-card">
        <h3 style="margin:0 0 16px; color:#D4AC0D">🌐 按国家统计</h3>
        <% if (byCountry && byCountry.length > 0) { %>
          <table class="a-table">
            <thead><tr><th>国家代码</th><th>访问次数</th><th>占比</th></tr></thead>
            <tbody>
              <% const totalCount = byCountry.reduce((s, c) => s + parseInt(c.cnt), 0); %>
              <% byCountry.forEach(function(c) { %>
                <tr>
                  <td><strong><%= c.country %></strong></td>
                  <td><%= c.cnt %></td>
                  <td style="color:#888"><%= totalCount > 0 ? Math.round(parseInt(c.cnt)/totalCount*100) : 0 %>%</td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <p style="color:#666">暂无数据</p>
        <% } %>
      </div>
    </div>

    <!-- GuandanSystem Page Breakdown (shown when source=gs or all) -->
    <% if ((source === 'gs' || source === 'all') && gsPageBreakdown && gsPageBreakdown.length > 0) { %>
    <div class="a-card" style="margin-top:20px; border-color:rgba(59,130,246,0.3)">
      <h3 style="margin:0 0 16px; color:#60a5fa">🏆 赛事系统 — 按页面统计</h3>
      <%
        const maxGsPage = Math.max(...gsPageBreakdown.map(p => parseInt(p.cnt)));
      %>
      <% gsPageBreakdown.forEach(function(p) { %>
        <div style="margin-bottom:10px">
          <div style="display:flex; justify-content:space-between; margin-bottom:3px">
            <span style="color:#93c5fd; font-size:0.85rem"><%= p.page.replace('gs-','') || p.page %></span>
            <strong style="color:#60a5fa"><%= p.cnt %></strong>
          </div>
          <div style="background:#222; border-radius:4px; height:8px; overflow:hidden">
            <div style="background:linear-gradient(90deg,#3b82f6,#60a5fa); height:100%; width:<%= Math.round(parseInt(p.cnt)/maxGsPage*100) %>%; border-radius:4px; transition:width 0.3s"></div>
          </div>
        </div>
      <% }) %>
    </div>
    <% } %>

    <!-- By Day -->
    <div class="a-card" style="margin-top:20px">
      <h3 style="margin:0 0 16px; color:#D4AC0D">📅 每日访问趋势（近<%= days %>天）</h3>
      <% if (byDay && byDay.length > 0) { %>
        <%
          const maxDay = Math.max(...byDay.map(d => parseInt(d.cnt)));
          const chartH = 120;
        %>
        <div style="overflow-x:auto">
          <div style="display:flex; align-items:flex-end; gap:4px; min-width:<%= byDay.length * 20 %>px; height:<%= chartH + 30 %>px; padding-bottom:24px; position:relative">
            <% byDay.forEach(function(d) { %>
              <%
                const barH = maxDay > 0 ? Math.max(4, Math.round(parseInt(d.cnt)/maxDay*chartH)) : 4;
                const dateStr = new Date(d.day).toLocaleDateString('zh-CN', {month:'2-digit', day:'2-digit'});
              %>
              <div style="display:flex; flex-direction:column; align-items:center; flex:1; min-width:16px">
                <div style="font-size:0.65rem; color:#888; margin-bottom:2px"><%= d.cnt %></div>
                <div title="<%= dateStr %>: <%= d.cnt %>次" style="background:linear-gradient(0deg,#D4AC0D,#F0C820); width:100%; height:<%= barH %>px; border-radius:3px 3px 0 0"></div>
                <div style="font-size:0.6rem; color:#555; margin-top:3px; transform:rotate(-45deg); transform-origin:top left; white-space:nowrap"><%= dateStr %></div>
              </div>
            <% }) %>
          </div>
        </div>
        <div style="margin-top:8px; text-align:right">
          <table class="a-table" style="font-size:0.8rem">
            <thead><tr><th>日期</th><th>访问次数</th></tr></thead>
            <tbody>
              <% byDay.slice().reverse().slice(0, 10).forEach(function(d) { %>
                <tr>
                  <td><%= new Date(d.day).toLocaleDateString('zh-CN') %></td>
                  <td><strong><%= d.cnt %></strong></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p style="color:#666; text-align:center; padding:30px">该时间段内暂无访问数据</p>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
