<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>监控控制台 | Monitor Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/scoreboard-admin.css">
  <style>
    .online-dot {
      display: inline-block; width: 8px; height: 8px;
      border-radius: 50%; margin-right: 5px; flex-shrink: 0;
    }
    .online-dot.active  { background: #4CAF50; box-shadow: 0 0 6px #4CAF50; animation: pulse-green 1.8s ease-in-out infinite; }
    .online-dot.offline { background: #555; }
    @keyframes pulse-green {
      0%, 100% { box-shadow: 0 0 4px #4CAF50; opacity: 1; }
      50%       { box-shadow: 0 0 10px #4CAF50; opacity: 0.7; }
    }
    .online-badge {
      display: inline-flex; align-items: center;
      font-size: 0.72rem; color: #4CAF50; font-weight: 600;
      white-space: nowrap;
    }
    .online-cnt-badge {
      display: inline-flex; align-items: center; gap: 4px;
      background: rgba(76,175,80,0.12); border: 1px solid rgba(76,175,80,0.35);
      border-radius: 10px; padding: 1px 8px; font-size: 0.75rem;
      color: #4CAF50; font-weight: 700;
    }
  </style>
</head>
<body>
<% const activePage = 'dashboard'; %>
<div class="sb-wrap">
  <%- include('_layout', { activePage }) %>

  <main class="sb-main">
    <div class="sb-page-head">
      <h1>🏠 控制台 · Dashboard</h1>
      <span style="color:#888; font-size:0.85rem">欢迎，<%= sbUser.display_name || sbUser.username %></span>
    </div>

    <!-- Stats Row -->
    <div class="stats-row">
      <div class="stat-box" style="border-color:rgba(76,175,80,0.5)">
        <div class="stat-num" style="color:#4CAF50">
          <span class="online-dot active" style="width:12px;height:12px;margin-right:6px"></span><%= onlineTotal ? onlineTotal.cnt : 0 %>
        </div>
        <div class="stat-lbl">当前在线 · Online Now <span style="font-size:0.7rem;color:#555">（5分钟内）</span></div>
      </div>
      <div class="stat-box">
        <div class="stat-num"><%= totalVisits30d ? totalVisits30d.cnt : 0 %></div>
        <div class="stat-lbl">近30天访问 · Visits (30d)</div>
      </div>
      <div class="stat-box">
        <div class="stat-num"><%= adStats ? adStats.imp || 0 : 0 %></div>
        <div class="stat-lbl">广告展示 · Impressions</div>
      </div>
      <div class="stat-box">
        <div class="stat-num"><%= adStats ? adStats.clk || 0 : 0 %></div>
        <div class="stat-lbl">广告点击 · Clicks</div>
      </div>
    </div>

    <div style="display:grid; grid-template-columns:2fr 3fr; gap:20px; margin-top:20px">
      <!-- Visit Stats by Region -->
      <div class="a-card">
        <h3 style="margin:0 0 16px; color:#D4AC0D">📍 区域访问分布（近30天）</h3>
        <% if (visitStats && visitStats.length > 0) { %>
          <table class="a-table">
            <thead>
              <tr><th>区域代码</th><th>访问次数</th><th>在线用户数</th></tr>
            </thead>
            <tbody>
              <% visitStats.forEach(function(v) { %>
                <tr>
                  <td><%= v.region_code %></td>
                  <td><strong><%= v.cnt %></strong></td>
                  <td>
                    <% if (parseInt(v.online_cnt) > 0) { %>
                      <span class="online-cnt-badge">
                        <span class="online-dot active" style="width:7px;height:7px;margin:0"></span>
                        <%= v.online_cnt %>
                      </span>
                    <% } else { %>
                      <span style="color:#444; font-size:0.78rem">—</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <p style="color:#666; font-size:0.88rem">暂无访问数据</p>
        <% } %>
      </div>

      <!-- Recent Visits -->
      <div class="a-card">
        <h3 style="margin:0 0 16px; color:#D4AC0D">🕐 最近访问记录</h3>
        <% if (recentVisits && recentVisits.length > 0) { %>
          <div style="overflow-y:auto; max-height:460px">
            <table class="a-table" style="font-size:0.78rem">
              <thead>
                <tr><th>状态</th><th>来源</th><th>时间</th><th>国家</th><th>地区</th><th>城市</th></tr>
              </thead>
              <tbody>
                <% recentVisits.forEach(function(v) { %>
                  <%
                    var ua = v.user_agent || '';
                    var isWeChat = /MicroMessenger/i.test(ua);
                    var isMobile = /Mobile|Android|iPhone|iPad/i.test(ua);
                  %>
                  <tr style="<%= v.is_active ? 'background:rgba(76,175,80,0.05)' : '' %>">
                    <td>
                      <% if (v.is_active) { %>
                        <span class="online-badge"><span class="online-dot active"></span>在线</span>
                      <% } else { %>
                        <span style="display:inline-flex;align-items:center;font-size:0.72rem;color:#555">
                          <span class="online-dot offline"></span>离线
                        </span>
                      <% } %>
                    </td>
                    <td>
                      <% if (isWeChat) { %>
                        <span style="display:inline-flex;align-items:center;gap:3px;background:rgba(7,193,96,0.15);border:1px solid rgba(7,193,96,0.4);border-radius:8px;padding:1px 7px;font-size:0.72rem;color:#07c160;font-weight:700;white-space:nowrap">
                          💬 微信
                        </span>
                      <% } else if (isMobile) { %>
                        <span style="font-size:0.72rem;color:#888">📱 手机</span>
                      <% } else { %>
                        <span style="font-size:0.72rem;color:#555">🖥 网页</span>
                      <% } %>
                    </td>
                    <td><%= new Date(v.visited_at).toLocaleString('zh-CN', {month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'}) %></td>
                    <td><%= v.country %></td>
                    <td><%= v.region_code %></td>
                    <td><%= v.city || '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="color:#666; font-size:0.88rem">暂无访问记录</p>
        <% } %>
      </div>
    </div>

    <!-- GuandanSystem Stats -->
    <div class="a-card" style="margin-top:20px; border-color:rgba(59,130,246,0.4)">
      <h3 style="margin:0 0 16px; color:#60a5fa">🏆 赛事系统（GuandanSystem）访问统计</h3>
      <div class="stats-row" style="margin-bottom:16px">
        <div class="stat-box" style="border-color:rgba(96,165,250,0.4)">
          <div class="stat-num" style="color:#60a5fa">
            <span class="online-dot active" style="width:10px;height:10px;background:#60a5fa;box-shadow:0 0 6px #60a5fa;margin-right:6px"></span><%= gsOnlineTotal ? gsOnlineTotal.cnt : 0 %>
          </div>
          <div class="stat-lbl">当前在线 · Online Now</div>
        </div>
        <div class="stat-box" style="border-color:rgba(96,165,250,0.3)">
          <div class="stat-num" style="color:#93c5fd"><%= gsTotalVisits30d ? gsTotalVisits30d.cnt : 0 %></div>
          <div class="stat-lbl">近30天访问 · Visits (30d)</div>
        </div>
      </div>
      <% if (gsVisitStats && gsVisitStats.length > 0) { %>
        <table class="a-table" style="font-size:0.85rem">
          <thead>
            <tr><th>区域代码</th><th>访问次数</th><th>在线用户数</th></tr>
          </thead>
          <tbody>
            <% gsVisitStats.forEach(function(v) { %>
              <tr>
                <td><%= v.region_code %></td>
                <td><strong><%= v.cnt %></strong></td>
                <td>
                  <% if (parseInt(v.online_cnt) > 0) { %>
                    <span class="online-cnt-badge" style="border-color:rgba(96,165,250,0.35);color:#60a5fa;background:rgba(96,165,250,0.1)">
                      <span class="online-dot active" style="width:7px;height:7px;margin:0;background:#60a5fa;box-shadow:0 0 5px #60a5fa"></span>
                      <%= v.online_cnt %>
                    </span>
                  <% } else { %>
                    <span style="color:#444; font-size:0.78rem">—</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p style="color:#555; font-size:0.85rem">暂无数据 — 请确认已在 GuandanSystem 配置 MONITOR_API_URL 环境变量</p>
      <% } %>
    </div>

    <!-- Regions Overview -->
    <% if (regions && regions.length > 0) { %>
    <div class="a-card" style="margin-top:20px">
      <h3 style="margin:0 0 16px; color:#D4AC0D">🗺️ 管辖区域</h3>
      <div style="display:flex; flex-wrap:wrap; gap:10px">
        <% regions.forEach(function(r) { %>
          <div style="background:rgba(212,172,13,0.1); border:1px solid rgba(212,172,13,0.3); border-radius:8px; padding:8px 16px; font-size:0.85rem">
            <strong style="color:#D4AC0D"><%= r.area_code %></strong>
            <span style="color:#ccc; margin-left:6px"><%= r.area_name_zh %></span>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <div style="margin-top:20px; text-align:center">
      <a href="/scoreboard/analytics" class="abtn abtn-primary" style="margin-right:10px">📈 查看详细统计</a>
      <a href="/scoreboard/ads" class="abtn abtn-secondary">📢 管理广告</a>
    </div>
  </main>
</div>
</body>
</html>
