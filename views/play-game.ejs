      '<span class="result-pname">' + esc(f.name) + (isMine?' <span style="color:#FFE066;font-size:.68rem;">（我）</span>':'') + '</span>' +
      '<span class="result-team-tag">' + tName + '</span>' +
    '</div>';
  });
  document.getElementById('result-order').innerHTML = html;
  document.getElementById('result-overlay').style.display = 'flex';
