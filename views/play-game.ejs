<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>掼蛋 · <%= roomCode %></title>
  <link rel="stylesheet" href="/css/style.css">
  <%- include('partials/pwa-head') %>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { height: 100%; overflow: hidden; margin: 0; }
    body {
      background: radial-gradient(ellipse at 50% 40%, #1d5c1d 0%, #0d2d0d 55%, #061306 100%);
      display: flex; flex-direction: column;
      font-family: -apple-system, "PingFang SC", sans-serif;
    }

    /* ═══════════════ 顶部状态栏 ═══════════════ */
    #top-bar {
      display: flex; align-items: center; padding: 7px 14px; gap: 10px;
      background: rgba(0,0,0,0.55); flex-shrink: 0; z-index: 10;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    /* 当前牌局：坐庄队(左,鲜亮) / 对方队(右,暗淡)，红蓝区分 */
    .tb-center { flex:1; text-align:center; }
    .tb-title  { font-size:.58rem; color:rgba(255,255,255,.42); letter-spacing:3px; }
    .room-code-sm { font-size:.76rem; font-weight:900; color:#FFE066; letter-spacing:2px; margin-top:1px; }
    .clv-box {
      display:flex; flex-direction:column; align-items:center;
      padding:2px 12px; border-radius:9px; min-width:52px; line-height:1.12;
      transition: all .2s;
    }
    .clv-box .clv-team { font-size:.56rem; letter-spacing:1px; font-weight:700; }
    .clv-box .clv-num  { font-size:1.22rem; font-weight:900; }
    .clv-box.t1 { background:rgba(192,0,15,.42); border:1px solid rgba(192,0,15,.75); }
    .clv-box.t1 .clv-team { color:#FFC2C2; }
    .clv-box.t1 .clv-num  { color:#FF7676; text-shadow:0 1px 6px rgba(192,0,15,.7); }
    .clv-box.t2 { background:rgba(0,85,187,.42); border:1px solid rgba(0,85,187,.75); }
    .clv-box.t2 .clv-team { color:#B8D0FF; }
    .clv-box.t2 .clv-num  { color:#6BA0FF; text-shadow:0 1px 6px rgba(0,85,187,.7); }
    .clv-box.banker { box-shadow:0 0 12px rgba(255,224,102,.3); }      /* 坐庄=鲜亮+微光 */
    .clv-box.dim    { opacity:.4; filter:saturate(.65); box-shadow:none; }  /* 对方=暗淡 */

    /* ═══════════════ 对家区域（上方） ═══════════════ */
    #zone-top {
      flex-shrink: 0; display: flex; justify-content: center; padding: 8px 16px 4px;
    }

    /* ═══════════════ 中央三列（左玩家 | 桌面 | 右玩家） ═══════════════ */
    #zone-mid {
      flex: 1; display: flex; align-items: stretch; min-height: 0;
      padding: 0 6px;
    }
    #zone-left, #zone-right {
      flex-shrink: 0; width: 64px; display: flex; align-items: center; justify-content: center;
    }
    #zone-center {
      flex: 1; display: flex; align-items: center; justify-content: center; position: relative;
    }

    /* ═══════════════ 玩家信息面板（通用） ═══════════════ */
    .pbox {
      display: flex; flex-direction: column; align-items: center; gap: 4px;
      border-radius: 12px; padding: 6px 8px;
      border: 2px solid rgba(255,255,255,0.06);
      background: rgba(0,0,0,0.3);
      transition: border-color .3s, box-shadow .3s;
      min-width: 0;
    }
    .pbox.team1 { border-color: rgba(192,0,15,.35); }
    .pbox.team2 { border-color: rgba(0,85,187,.35); }
    /* 出牌中：发光边框 + 脉冲 */
    .pbox.active {
      border-color: #FFE066 !important;
      box-shadow: 0 0 0 2px rgba(212,172,13,.25);
      animation: pulse-border 1.4s ease-in-out infinite;
    }
    @keyframes pulse-border {
      0%, 100% { box-shadow: 0 0 0 2px rgba(212,172,13,.25); }
      50%       { box-shadow: 0 0 0 6px rgba(212,172,13,.05); }
    }

    /* 头像圆圈 */
    .pbox-avatar {
      width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: .72rem; font-weight: 900; color: #fff; letter-spacing: 0;
    }
    .pbox-avatar.team1 { background: rgba(192,0,15,.6); }
    .pbox-avatar.team2 { background: rgba(0,85,187,.6); }
    .pbox-avatar.active { background: #D4AC0D; color: #1a1a2e; }

    /* 名字 */
    .pbox-name {
      font-size: .64rem; color: rgba(255,255,255,.65); text-align: center; letter-spacing: 1px;
      max-width: 70px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .pbox-name.active { color: #FFE066; font-weight: 700; }
    .pbox-name.offline { color: rgba(255,120,120,.75); font-style: italic; }
    .h-pbox-name.offline { color: rgba(255,120,120,.75); font-style: italic; }
    .pbox-avatar.waiting-empty, .h-pbox-avatar.waiting-empty {
      opacity: .4; border-style: dashed !important;
    }
    .pbox.waiting-empty { opacity: .7; }

    /* 队友标签 */
    .buddy-tag {
      font-size: .55rem; padding: 1px 5px; border-radius: 5px; font-weight: 700; letter-spacing: 1px;
      background: rgba(212,172,13,.2); color: #D4AC0D; border: 1px solid rgba(212,172,13,.3);
    }

    /* 牌数徽章 */
    .card-count-badge {
      font-size: .62rem; font-weight: 700; padding: 1px 6px; border-radius: 8px;
      background: rgba(255,255,255,.1); color: rgba(255,255,255,.7);
      border: 1px solid rgba(255,255,255,.12);
    }

    /* 完成位置 */
    .finish-badge {
      font-size: .62rem; font-weight: 700; padding: 1px 7px; border-radius: 7px; letter-spacing: 1px;
    }
    .finish-badge.p1 { background:#D4AC0D; color:#1a1a2e; }
    .finish-badge.p2 { background:rgba(255,255,255,.18); color:#fff; }
    .finish-badge.p3 { background:rgba(255,255,255,.1);  color:rgba(255,255,255,.65); }
    .finish-badge.p4 { background:rgba(192,0,15,.18); color:#F08080; }

    /* ─── 顶部玩家水平牌背 ─── */
    .pbox-top {
      max-width: min(260px, 78vw);
    }
    .card-fan-h {
      display: flex; justify-content: center; flex-wrap: nowrap; overflow: hidden;
    }
    .cbk-h {
      width: 20px; height: 30px; border-radius: 4px; flex-shrink: 0;
      background: linear-gradient(145deg, #9E0010, #C0000F, #7a000c);
      border: 1px solid rgba(255,255,255,.18);
      box-shadow: 1px 1px 3px rgba(0,0,0,.5), inset 0 0 0 1px rgba(255,255,255,.06);
      margin-left: -6px; position: relative; overflow: hidden;
    }
    .cbk-h::after {
      content: ''; position: absolute; inset: 2px; border-radius: 2px;
      border: 1px solid rgba(255,255,255,.1);
      background: repeating-linear-gradient(
        45deg, transparent 0, transparent 3px, rgba(255,255,255,.03) 3px, rgba(255,255,255,.03) 4px
      );
    }
    .cbk-h:first-child { margin-left: 0; }

    /* ─── 侧边玩家竖直牌背 ─── */
    .pbox-side { width: 56px; }
    .card-fan-v {
      display: flex; flex-direction: column; align-items: center;
    }
    .cbk-v {
      width: 32px; height: 20px; border-radius: 4px; flex-shrink: 0;
      background: linear-gradient(145deg, #9E0010, #C0000F, #7a000c);
      border: 1px solid rgba(255,255,255,.18);
      box-shadow: 1px 1px 3px rgba(0,0,0,.5), inset 0 0 0 1px rgba(255,255,255,.06);
      margin-top: -7px; position: relative; overflow: hidden;
    }
    .cbk-v::after {
      content: ''; position: absolute; inset: 2px; border-radius: 2px;
      border: 1px solid rgba(255,255,255,.1);
      background: repeating-linear-gradient(
        45deg, transparent 0, transparent 3px, rgba(255,255,255,.03) 3px, rgba(255,255,255,.03) 4px
      );
    }
    .cbk-v:first-child { margin-top: 0; }

    /* ═══════════════ 中央桌面 ═══════════════ */
    #table-felt {
      width: min(220px, 58vw); height: min(180px, 34vw);
      max-height: 190px;
      border-radius: 50%;
      background: radial-gradient(ellipse, rgba(255,255,255,.04) 0%, transparent 70%);
      border: 1px solid rgba(255,255,255,.07);
      display: flex; align-items: center; justify-content: center;
      position: relative; flex-direction: column; gap: 6px;
    }
    #leader-badge {
      display: none; font-size: .68rem; color: #FFE066; letter-spacing: 2px;
      font-weight: 700; text-align: center;
      background: rgba(212,172,13,.15); border-radius: 10px; padding: 3px 10px;
      border: 1px solid rgba(212,172,13,.3);
    }
    #play-hint { color: rgba(255,255,255,.18); font-size: .82rem; letter-spacing: 3px; text-align: center; }
    .trick-who {
      font-size: .68rem; color: rgba(255,255,255,.7); letter-spacing: 1px; text-align: center;
      background: rgba(0,0,0,.35); border-radius: 8px; padding: 2px 9px;
    }
    .trick-cards { display: flex; justify-content: center; flex-wrap: wrap; gap: 2px; }

    /* 迷你牌面（中央出牌区） */
    .mc {
      width: 30px; height: 44px; border-radius: 4px; background: #fff;
      border: 1px solid #ddd; box-shadow: 1px 2px 4px rgba(0,0,0,.4);
      display: flex; flex-direction: column; padding: 2px 2px; flex-shrink: 0;
      position: relative;
    }
    .mc-top  { font-size: .72rem; font-weight: 900; line-height: 1.1; }
    .mc-suit { font-size: .65rem; line-height: 1; }
    .mc.joker-big   { background: linear-gradient(145deg,#FFF3C0,#FFE066); }
    .mc.joker-small { background: linear-gradient(145deg,#F0F0F0,#E0E0E0); }
    .mc-joker-lbl {
      font-size: .58rem; font-weight: 900; text-align: center; width: 100%;
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); letter-spacing: 1px;
    }
    .trick-more { font-size: .65rem; color: rgba(255,255,255,.45); }

    /* 出牌赢回动画 */
    #trick-won-flash {
      display: none; position: absolute; z-index: 5;
      color: #FFE066; font-size: .78rem; font-weight: 700; letter-spacing: 2px;
      background: rgba(0,0,0,.55); border-radius: 10px; padding: 4px 12px;
      white-space: nowrap; pointer-events: none;
    }
    .fade-up { animation: fadeUp 1.3s ease forwards; }
    @keyframes fadeUp {
      0%   { opacity: 1; transform: translateY(0); }
      100% { opacity: 0; transform: translateY(-24px); }
    }

    /* ═══════════════ 我的手牌区 ═══════════════ */
    #my-hand-area {
      flex-shrink: 0; background: rgba(0,0,0,.4);
      border-top: 1px solid rgba(255,255,255,.07);
      padding-bottom: env(safe-area-inset-bottom, 4px);
    }
    #my-info-row {
      display: flex; align-items: center; gap: 7px; padding: 6px 14px 4px;
    }
    .my-team-dot {
      width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
    }
    .my-team-dot.t1 { background: #C0000F; box-shadow: 0 0 5px #C0000F; }
    .my-team-dot.t2 { background: #0055BB; box-shadow: 0 0 5px #0055BB; }
    #my-name      { font-size: .78rem; color: #fff; font-weight: 700; letter-spacing: 1px; }
    #sel-info     { font-size: .7rem; color: #FFE066; letter-spacing: 1px; display: none; }
    #my-card-count { margin-left: auto; font-size: .65rem; color: rgba(255,255,255,.38); }
    #btn-cancel {
      font-size: .65rem; color: rgba(255,255,255,.45); background: none; border: none;
      padding: 2px 6px; cursor: pointer; letter-spacing: 1px;
      display: none;
    }
    #my-turn-badge {
      font-size: .62rem; font-weight: 700; padding: 2px 7px; border-radius: 8px;
      background: rgba(212,172,13,.2); color: #FFE066; border: 1px solid rgba(212,172,13,.3);
      display: none;
    }

    /* 手牌横向滚动 */
    #hand-scroll {
      overflow-x: auto; overflow-y: hidden; display: flex;
      padding: 4px 14px 6px;
      scrollbar-width: none; -ms-overflow-style: none;
    }
    #hand-scroll::-webkit-scrollbar { display: none; }

    /* 单张手牌 */
    .hand-card {
      flex-shrink: 0; width: 52px; height: 76px; border-radius: 8px;
      background: #fff; border: 1px solid #ddd;
      box-shadow: 2px 3px 8px rgba(0,0,0,.45);
      margin-left: -18px;
      display: flex; flex-direction: column; align-items: flex-start; padding: 4px 5px;
      cursor: pointer;
      transition: transform .12s ease, box-shadow .12s ease, outline .1s;
      position: relative; user-select: none; -webkit-tap-highlight-color: transparent;
    }
    .hand-card:first-child { margin-left: 0; }
    .hand-card.selected {
      transform: translateX(12px);
      box-shadow: -3px 5px 18px rgba(0,0,0,.55);
      outline: 2px solid #FFE066;
      z-index: 30;
    }

    /* 按点数竖排成列 */
    .hand-col {
      display: flex; flex-direction: column; align-items: flex-start;
      flex-shrink: 0; position: relative; margin-left: 7px;
    }
    .hand-col:first-child { margin-left: 0; }
    .hand-col .hand-card { margin-left: 0; }
    .hand-col .hand-card.stacked { margin-top: -52px; }        /* 76-52=24px 露出点数+花色 */
    body.mode-6p .hand-col .hand-card.stacked { margin-top: -40px; }
    body.mode-6p .hand-col { margin-left: 3px; }
    #hand-scroll { align-items: flex-end; }
    #hand-scroll-6p { align-items: flex-end; }

    .card-top    { font-size: .92rem; font-weight: 900; line-height: 1; }
    .card-suit   { font-size: .84rem; line-height: 1; margin-top: 1px; }
    .card-center {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      font-size: 1.2rem; opacity: .07;
    }
    .hand-card.joker-big   { background: linear-gradient(145deg,#FFF3C0,#FFE066); }
    .hand-card.joker-small { background: linear-gradient(145deg,#F5F5F5,#E0E0E0); }
    .joker-label {
      font-size: .68rem; font-weight: 900; text-align: center; width: 100%;
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); letter-spacing: 1px;
    }

    /* 手牌区边缘渐隐提示有更多牌 */
    #hand-scroll-wrap { position: relative; }
    #hand-scroll-wrap::after {
      content: ''; position: absolute; right: 0; top: 0; bottom: 0; width: 28px;
      background: linear-gradient(to right, transparent, rgba(0,0,0,.4));
      pointer-events: none;
    }

    /* ═══════════════ 操作区 ═══════════════ */
    #action-bar {
      display: flex; align-items: center; gap: 8px;
      padding: 6px 14px 8px;
      background: rgba(0,0,0,.3); flex-shrink: 0;
    }
    #action-hint {
      flex: 1; font-size: .72rem; color: rgba(255,255,255,.38); letter-spacing: 1px;
      line-height: 1.4;
    }
    #action-hint.my-lead  { color: #80D880; }
    #action-hint.my-beat  { color: #FFE066; }
    .action-btn {
      padding: 10px 16px; border-radius: 10px; border: none;
      font-size: .82rem; font-weight: 700; letter-spacing: 1px; cursor: pointer;
      transition: all .18s; white-space: nowrap;
    }
    .action-btn.pass {
      background: rgba(255,255,255,.1); color: rgba(255,255,255,.55);
      border: 1px solid rgba(255,255,255,.18);
    }
    .action-btn.pass:hover:not(:disabled) { background: rgba(255,255,255,.18); }
    .action-btn.pass:disabled { opacity: .35; cursor: default; }
    .action-btn.play {
      background: linear-gradient(135deg,#C0000F,#8B0000); color: #fff;
      box-shadow: 0 3px 12px rgba(192,0,15,.45);
    }
    .action-btn.play:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(192,0,15,.5); }
    .action-btn.play:disabled { background: #444; box-shadow: none; cursor: default; }

    /* 操作无效提示 toast */
    #err-toast {
      position: fixed; bottom: 110px; left: 50%; transform: translateX(-50%);
      background: rgba(192,0,15,.92); color: #fff; font-size: .8rem; font-weight: 700;
      padding: 8px 18px; border-radius: 20px; z-index: 60;
      display: none; letter-spacing: 1px; white-space: nowrap;
      box-shadow: 0 4px 16px rgba(0,0,0,.4);
    }

    /* ═══════════════ 加载层 ═══════════════ */
    #loading-overlay {
      position: fixed; inset: 0; z-index: 100;
      background: radial-gradient(ellipse,#1a4a1a,#061a06);
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px;
    }
    #loading-overlay .spin { font-size: 2.4rem; animation: spin 1.1s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    #loading-overlay p { color: rgba(255,255,255,.55); font-size: .88rem; letter-spacing: 2px; }

    /* ═══════════════ 错误层 ═══════════════ */
    #err-box {
      display: none; position: fixed; inset: 0; z-index: 200;
      background: rgba(0,0,0,.88); align-items: center; justify-content: center;
    }
    #err-box .err-inner {
      background: #1a0505; border: 1px solid rgba(192,0,15,.4); border-radius: 18px;
      padding: 30px 26px; text-align: center; max-width: 320px;
    }
    #err-box p { color: #F08080; margin: 0 0 18px; font-size: .9rem; line-height: 1.6; }
    #err-box a { color: #FFE066; font-size: .84rem; }

    /* ═══════════════ 结算层 ═══════════════ */
    #result-overlay {
      display: none; position: fixed; inset: 0; z-index: 300;
      background: rgba(0,0,0,.93); flex-direction: column; align-items: center; justify-content: center;
    }
    .result-wrap {
      max-width: 340px; width: 90%; text-align: center;
      background: rgba(255,255,255,.04); border-radius: 22px; padding: 32px 26px 26px;
      border: 1px solid rgba(212,172,13,.22);
    }
    .result-type { font-size: 3rem; font-weight: 900; letter-spacing: 6px; margin-bottom: 4px; }
    .result-type.win  { color: #FFE066; text-shadow: 0 0 28px rgba(212,172,13,.6); }
    .result-type.lose { color: #80A8E8; }
    .result-level-line {
      font-size: .82rem; color: rgba(255,255,255,.5); letter-spacing: 1px; margin-bottom: 18px;
    }
    .result-level-line strong { color: #FFE066; }
    .result-order { display: flex; flex-direction: column; gap: 7px; margin-bottom: 22px; }
    .result-row {
      display: flex; align-items: center; gap: 10px;
      background: rgba(255,255,255,.05); border-radius: 9px; padding: 8px 13px;
      border: 1px solid rgba(255,255,255,.07);
    }
    .result-pos { font-size: .7rem; font-weight: 700; width: 34px; flex-shrink: 0; }
    .result-pos.p1 { color: #D4AC0D; }
    .result-pos.p2 { color: #bbb; }
    .result-pos.p3 { color: #777; }
    .result-pos.p4 { color: #F08080; }
    .result-pname { flex: 1; font-size: .88rem; color: #fff; font-weight: 700; text-align: left; }
    .result-team-tag { font-size: .68rem; color: rgba(255,255,255,.38); }
    .result-btns { display: flex; gap: 8px; }
    .result-btn {
      flex: 1; padding: 12px; border-radius: 11px; border: none; cursor: pointer;
      font-size: .88rem; font-weight: 900; letter-spacing: 2px; color: #fff;
    }
    .result-btn.primary {
      background: linear-gradient(135deg,#C0000F,#8B0000);
      box-shadow: 0 4px 14px rgba(192,0,15,.4);
    }
    .result-btn.secondary {
      background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.18);
    }

    /* ═══════════════ 六人赛事 · 六边形布局 ═══════════════ */
    body.mode-6p #zone-top, body.mode-6p #zone-mid,
    body.mode-6p #my-hand-area, body.mode-6p #action-bar { display: none !important; }

    body.mode-6p #game-6p-board { display: flex !important; }

    #game-6p-board {
      display: none;
      flex-direction: column;
      flex: 1;
      min-height: 0;
      position: relative;
      overflow: hidden;
    }

    /* 六边形主板（玩家围坐）*/
    #hex-board {
      position: relative;
      width: 100%;
      max-width: 680px;
      margin: 0 auto;
      flex: 1;
      min-height: 280px;
    }

    /* 中央牌桌区 */
    #hex-center {
      position: absolute;
      left: 50%; top: 50%;
      transform: translate(-50%,-50%);
      width: 200px; height: 160px;
      background: radial-gradient(ellipse, #0a2e0a 0%, #061506 100%);
      border-radius: 50%;
      border: 2px solid rgba(212,172,13,.2);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      z-index: 5;
    }

    /* 六个座位格：绝对定位在六边形顶点 */
    .h-pbox {
      position: absolute;
      width: 100px;
      display: flex; flex-direction: column; align-items: center; gap: 4px;
      z-index: 10;
    }
    /* 顶点位置（%值以 hex-board 宽高为基准，用 JS 动态设置）*/
    .h-pbox-avatar {
      width: 38px; height: 38px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: .85rem; font-weight: 900; color: #fff;
      transition: all .3s;
    }
    .h-pbox-avatar.team1 { background: linear-gradient(135deg,#C0000F,#8B0000); }
    .h-pbox-avatar.team2 { background: linear-gradient(135deg,#1a4ba8,#0d2d5c); }
    .h-pbox-avatar.active { box-shadow: 0 0 0 3px #FFE066; animation: pulse-border 1.4s ease-in-out infinite; }
    .h-pbox-name { font-size: .68rem; color: rgba(255,255,255,.8); font-weight: 700; text-align: center; max-width: 90px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .h-pbox-info { font-size: .6rem; color: rgba(255,255,255,.4); text-align: center; }
    .h-buddy-tag { font-size: .55rem; background: rgba(212,172,13,.25); color: #FFE066; border-radius: 6px; padding: 1px 5px; }
    .h-card-fan { display: flex; gap: -4px; }
    .h-cbk { width: 14px; height: 20px; background: #1a3a6e; border-radius: 2px; border: 1px solid rgba(255,255,255,.2); margin: 0 -2px; }
    .h-finish-badge { font-size: .6rem; font-weight: 900; border-radius: 8px; padding: 2px 6px; }
    .h-finish-badge.p1 { background: #D4AC0D; color: #000; }
    .h-finish-badge.p2 { background: rgba(255,255,255,.2); color: #fff; }
    .h-finish-badge.p3 { background: rgba(255,255,255,.1); color: rgba(255,255,255,.6); }

    /* 六人手牌区 */
    #my-hand-6p { padding: 6px 0 2px; background: rgba(0,0,0,.3); }
    #my-info-6p {
      display: flex; align-items: center; gap: 8px; padding: 4px 10px;
      font-size: .78rem;
    }
    #my-hand-scroll-6p { overflow-x: auto; padding: 4px 8px 8px; }

    /* 六人动作栏 */
    #action-bar-6p {
      display: flex; align-items: center; gap: 8px; padding: 6px 10px;
      background: rgba(0,0,0,.4);
    }

    /* ═══════════════ 进贡层 ═══════════════ */
    #tribute-overlay {
      display: none; position: fixed; inset: 0; z-index: 280;
      background: rgba(0,0,0,.88); backdrop-filter: blur(6px);
      flex-direction: column; align-items: center; justify-content: center; gap: 14px;
      padding: 20px;
    }
    .tribute-title {
      font-size: 1.3rem; font-weight: 900; color: #FFE066; letter-spacing: 4px; margin-bottom: 4px;
    }
    .tribute-sub { font-size: .78rem; color: rgba(255,255,255,.45); letter-spacing: 2px; }
    .tribute-card-display {
      background: rgba(255,255,255,.06); border: 1px solid rgba(212,172,13,.3);
      border-radius: 14px; padding: 14px 20px; text-align: center; min-width: 160px;
    }
    .tribute-card-display .tc-label { font-size: .68rem; color: rgba(255,255,255,.4); letter-spacing: 2px; margin-bottom: 8px; }
    .tribute-card-display .tc-card { font-size: 2.2rem; }
    .tribute-return-area { width: 100%; max-width: 380px; }
    .tribute-return-area .tr-label { font-size: .72rem; color: rgba(255,255,255,.5); letter-spacing: 2px; margin-bottom: 8px; text-align: center; }
    #tribute-return-hand { display: flex; flex-wrap: wrap; gap: 6px; justify-content: center; max-height: 200px; overflow-y: auto; }
    #tribute-return-hand .card {
      cursor: pointer; border-radius: 6px; border: 2px solid transparent;
      transition: all .2s; transform-origin: bottom center;
    }
    #tribute-return-hand .card.selected { border-color: #FFE066; transform: translateY(-6px); }
    #tribute-return-btn {
      display: block; width: 100%; max-width: 200px; margin: 14px auto 0;
      padding: 12px; border-radius: 12px; border: none; cursor: pointer;
      background: linear-gradient(135deg,#C0000F,#8B0000); color: #fff;
      font-size: .9rem; font-weight: 900; letter-spacing: 3px;
    }
    #tribute-return-btn:disabled { opacity: .4; cursor: not-allowed; }
    .tribute-waiting-text { color: rgba(255,255,255,.5); font-size: .85rem; letter-spacing: 2px; }
    .tribute-giver-info { background: rgba(255,255,255,.06); border-radius: 12px; padding: 14px 20px; text-align: center; }
    .tribute-giver-info .tgi-card { font-size: 1.6rem; margin-bottom: 6px; }
    .tribute-giver-info .tgi-text { font-size: .78rem; color: rgba(255,255,255,.55); }
    .tribute-resisted { font-size: 1rem; color: #FFE066; letter-spacing: 2px; }
    /* 进贡记录列表 */
    #tribute-log { width: 100%; max-width: 340px; display: flex; flex-direction: column; gap: 6px; }
    .tribute-log-item { background: rgba(255,255,255,.05); border-radius: 8px; padding: 8px 12px; font-size: .75rem; color: rgba(255,255,255,.6); text-align: center; }
    .tribute-log-item.done { color: #80D4A8; }

    /* ═══════════════ 等候层 ═══════════════ */
    #wait-overlay {
      display: none; position: fixed; inset: 0; z-index: 150;
      background: radial-gradient(ellipse at 50% 40%, #1d5c1d 0%, #0d2d0d 55%, #061306 100%);
      flex-direction: column; align-items: center; justify-content: center; gap: 0;
      padding: 20px;
    }
    .wait-logo { width: 52px; height: 52px; border-radius: 50%; margin-bottom: 14px; }
    .wait-title {
      font-size: 1rem; font-weight: 900; color: #FFE066; letter-spacing: 3px; margin-bottom: 4px;
    }
    .wait-sub {
      font-size: .72rem; color: rgba(255,255,255,.4); letter-spacing: 2px; margin-bottom: 22px;
    }
    /* 进度条 */
    .wait-progress {
      font-size: 1.6rem; font-weight: 900; color: #fff; letter-spacing: 2px; margin-bottom: 4px;
    }
    .wait-progress span { color: #FFE066; }
    .wait-progress-label {
      font-size: .72rem; color: rgba(255,255,255,.4); letter-spacing: 3px; margin-bottom: 20px;
    }
    /* 座位格 */
    .wait-seats {
      display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
      width: 100%; max-width: 320px; margin-bottom: 20px;
    }
    .wait-seat {
      border-radius: 12px; padding: 12px 14px;
      background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
      display: flex; align-items: center; gap: 10px;
      transition: all .3s;
    }
    .wait-seat.filled { background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.2); }
    .wait-seat.me     { border-color: rgba(212,172,13,.5); background: rgba(212,172,13,.08); }
    .wait-seat-num {
      width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center;
      justify-content: center; font-size: .72rem; font-weight: 700; flex-shrink: 0;
      background: rgba(255,255,255,.08); color: rgba(255,255,255,.4);
    }
    .wait-seat.filled .wait-seat-num { background: rgba(255,255,255,.18); color: #fff; }
    .wait-seat.me .wait-seat-num { background: rgba(212,172,13,.3); color: #FFE066; }
    .wait-seat-info { flex: 1; min-width: 0; }
    .wait-seat-name { font-size: .82rem; color: rgba(255,255,255,.35); }
    .wait-seat.filled .wait-seat-name { color: #fff; font-weight: 700; }
    .wait-seat.me .wait-seat-name { color: #FFE066; }
    .wait-seat-team { font-size: .62rem; color: rgba(255,255,255,.25); letter-spacing: 1px; margin-top: 2px; }
    .wait-seat.filled .wait-seat-team { color: rgba(255,255,255,.45); }
    /* 房间号分享区（私人房间显示） */
    #wait-room-code-box {
      display: none; text-align: center; background: rgba(0,0,0,.3);
      border: 1px solid rgba(212,172,13,.25); border-radius: 14px;
      padding: 14px 20px; width: 100%; max-width: 320px; margin-bottom: 14px;
    }
    #wait-room-code-box .wrc-label { font-size: .65rem; color: rgba(212,172,13,.7); letter-spacing: 4px; margin-bottom: 6px; }
    #wait-room-code-box .wrc-value { font-size: 2rem; font-weight: 900; color: #FFE066; letter-spacing: 10px; }
    #wait-room-code-box .wrc-copy  {
      margin-top: 8px; font-size: .72rem; color: rgba(212,172,13,.7); cursor: pointer;
      padding: 4px 14px; border: 1px solid rgba(212,172,13,.3); border-radius: 12px;
      display: inline-block; letter-spacing: 1px;
    }
    #wait-room-code-box .wrc-copy:hover { color: #FFE066; border-color: rgba(212,172,13,.5); }
    /* 等候动画点 */
    .wait-dots { font-size: .82rem; color: rgba(255,255,255,.3); letter-spacing: 4px; }
    .wait-dots span { animation: dotBlink 1.4s ease infinite; }
    .wait-dots span:nth-child(2) { animation-delay: .2s; }
    .wait-dots span:nth-child(3) { animation-delay: .4s; }
    @keyframes dotBlink { 0%,80%,100%{opacity:.2} 40%{opacity:1} }
  </style>
</head>
<body>

