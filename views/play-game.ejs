}

function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

/* ════════════════════════════════════════════════
 * 进贡 (Tribute) 事件处理
 * ════════════════════════════════════════════════ */
socket.on('tribute:phase', function(d) {
  var exchanges = d.exchanges || [];
  var overlay   = document.getElementById('tribute-overlay');
  overlay.style.display = 'flex';

  /* 判断我在进贡中的角色 */
  var myEx    = exchanges.find(function(e){ return e.giverId   === myPlayerId; });
  var recvEx  = exchanges.find(function(e){ return e.receiverId=== myPlayerId; });
  var resisted= myEx && myEx.resisted;

  /* 先全隐藏所有面板 */
  ['tribute-spectator','tribute-giver-panel','tribute-resist-panel','tribute-receiver-panel']
    .forEach(function(id){ document.getElementById(id).style.display='none'; });

  if (resisted) {
    document.getElementById('tribute-resist-panel').style.display = 'flex';
  } else if (myEx && !recvEx) {
    /* 我是进贡方（系统已自动选好牌并发给接收方，等还贡） */
    document.getElementById('tribute-giver-panel').style.display = 'flex';
    document.getElementById('tribute-given-card').textContent  = cardEmoji(myEx.tributeCard);
    document.getElementById('tribute-given-text').textContent  = '已自动进贡最大牌';
  } else if (recvEx && !recvEx.resisted) {
    /* 我是接收方：需要选一张还贡 */
    showTributeReceiverPanel(recvEx);
  } else {
    /* 旁观（本局不涉及进贡或角色待定）*/
    document.getElementById('tribute-spectator').style.display  = 'flex';
    buildTributeLog(exchanges);
  }
});

socket.on('tribute:exchange_done', function(d) {
  /* 更新进贡日志（旁观者 / 抗贡方显示） */
  var logEl = document.getElementById('tribute-log');
  if (!logEl) return;
  var item = document.createElement('div');
  item.className = 'tribute-log-item done';
  item.textContent = '✅ 进贡 ' + cardEmoji(d.tributeCard) + ' ↔ 还贡 ' + cardEmoji(d.returnCard);
  logEl.appendChild(item);
  /* 若我是进贡方且已收到还贡，可关闭进贡面板 */
  if (d.giverId === myPlayerId) {
    document.getElementById('tribute-giver-panel').style.display = 'none';
    var spec = document.getElementById('tribute-spectator');
    spec.style.display = 'flex';
    buildTributeLog([{ done: true, tributeCard: d.tributeCard, returnCard: d.returnCard }]);
  }
});

socket.on('tribute:done', function() {
  document.getElementById('tribute-overlay').style.display = 'none';
  tributeSelectedCard = null;
});

function showTributeReceiverPanel(ex) {
  document.getElementById('tribute-receiver-panel').style.display = 'flex';
  document.getElementById('tribute-received-display').textContent = cardEmoji(ex.tributeCard);
  /* 从哪里进贡的提示（可选） */
  document.getElementById('tribute-from-name').textContent = '';

  /* 渲染我的手牌供选择（不含已进贡的牌） */
  var handEl = document.getElementById('tribute-return-hand');
  handEl.innerHTML = '';
  tributeSelectedCard = null;
  document.getElementById('tribute-return-btn').disabled = true;

  myHand.forEach(function(code, idx) {
    var card = document.createElement('div');
    card.className = 'card';
    card.innerHTML = miniCardHtml(code);
    card.addEventListener('click', function() {
      document.querySelectorAll('#tribute-return-hand .card').forEach(function(c){ c.classList.remove('selected'); });
      card.classList.add('selected');
      tributeSelectedCard = code;
      document.getElementById('tribute-return-btn').disabled = false;
    });
    handEl.appendChild(card);
  });
}

function doTributeReturn() {
  if (!tributeSelectedCard) return;
  socket.emit('tribute:return', { token: MY_TOKEN, roomCode: ROOM_CODE, returnCard: tributeSelectedCard });
  document.getElementById('tribute-return-btn').disabled = true;
}

function buildTributeLog(exchanges) {
  var logEl = document.getElementById('tribute-log');
  if (!logEl) return;
  logEl.innerHTML = '';
  exchanges.forEach(function(e) {
    var item = document.createElement('div');
    item.className = 'tribute-log-item' + (e.done ? ' done' : '');
    if (e.resisted) item.textContent = '🛡️ 持3大王，抗贡';
    else if (e.done) item.textContent = '✅ 进贡 ' + cardEmoji(e.tributeCard) + ' ↔ 还 ' + cardEmoji(e.returnCard);
    else item.textContent = '⏳ 等待还贡中...';
    logEl.appendChild(item);
  });
}

function cardEmoji(code) {
  if (!code) return '—';
  if (code === 'BJ') return '🃏大王';
  if (code === 'LJ') return '🃏小王';
  var sym = {S:'♠',H:'♥',D:'♦',C:'♣'}[code[0]] || code[0];
  var rk  = code.slice(1) === 'T' ? '10' : code.slice(1);
  return sym + rk;
}

/* ════════════════════════════════════════════════
 * 六边形游戏区渲染
 * ════════════════════════════════════════════════ */

/* 六边形顶点位置（百分比，以 hex-board 为基准）
   座位排列（从我座位=1开始顺时针）：
   seat 1=bottom-center, 2=bottom-right, 3=top-right,
   4=top-center, 5=top-left, 6=bottom-left
*/
var HEX_POS = [
  null,                      // placeholder index 0
  { left:'50%', top:'82%' },  // seat 1 = bottom-center (me)
  { left:'82%', top:'62%' },  // seat 2 = bottom-right
  { left:'82%', top:'22%' },  // seat 3 = top-right
  { left:'50%', top:'5%'  },  // seat 4 = top-center
  { left:'18%', top:'22%' },  // seat 5 = top-left
  { left:'18%', top:'62%' },  // seat 6 = bottom-left
];

function init6pBoard(d) {
  levelTeam1 = d.levelTeam1 || 2;
  levelTeam2 = d.levelTeam2 || 2;
  updateCurrentLevel();
  document.getElementById('my-name-6p').textContent = MY_NAME_LS;
  document.getElementById('my-card-count-6p').textContent = myHand.length + '张';
  document.getElementById('my-team-dot-6p').className = 'my-team-dot ' + (myTeam===1?'t1':'t2');

  /* 定位六个座位格：按我的实际 seat 偏移 */
  var total = 6;
  for (var i = 0; i < total; i++) {
    var displayIdx = i + 1; // 1..6: 相对于我的顺时针偏移
    var actualSeat = ((mySeat - 1 + i) % total) + 1;
    var el = document.getElementById('h-seat-' + actualSeat);
    if (!el) continue;
    var pos = HEX_POS[displayIdx];
    if (!pos) continue;
    el.style.left       = pos.left;
    el.style.top        = pos.top;
    el.style.transform  = 'translate(-50%,-50%)';
    el.dataset.displayIdx = displayIdx;
  }

  render6pPlayers(d.players, [], null);
  render6pHand(myHand);
  document.getElementById('action-hint-6p').textContent = '已连接，等待游戏开始...';
  syncButtons6p();
}

function render6pPlayers(pList, finOrder, turnSeat) {
  if (!pList || !pList.length) return;
  var total = 6;
  for (var i = 0; i < total; i++) {
    var actualSeat = ((mySeat - 1 + i) % total) + 1;
    var p        = pList.find(function(x){ return x.seat === actualSeat; });
    var el       = document.getElementById('h-seat-' + actualSeat);
    if (!el) continue;

    var finItem  = (finOrder||[]).find(function(f){ return f.seat === actualSeat; });
    var isActive = (turnSeat === actualSeat);
    var isBuddy  = p && (p.team === myTeam);
    var isMe     = p && p.isMe;
    var offline  = (connMap[actualSeat] === false) && !isMe;
    var label    = isMe ? (MY_NAME_LS || '我') : (p ? esc(p.name) : '等待...');
    if (offline) label += ' 📴';
    var initials = label.replace(/^玩家/,'').replace(/ 📴$/,'').slice(0,2);
    var teamCls  = p ? (p.team===1?'team1':'team2') : 'team2';

    var finBadge = '';
    if (finItem) {
      finBadge = '<div class="h-finish-badge ' + (POS_CLASS[finItem.position]||'p3') + '">' +
        (POS_LABELS[finItem.position]||finItem.position+'游') + '</div>';
    }

    var cardBacks = '';
    if (p && !finItem) {
      var cnt = Math.min(p.cardCount||0, 6);
      for (var j = 0; j < cnt; j++) cardBacks += '<div class="h-cbk"></div>';
    }

    el.innerHTML =
      '<div class="h-pbox-avatar ' + teamCls + (isActive?' active':'') + '">' + initials + '</div>' +
      '<div class="h-pbox-name' + (offline?' offline':'') + '">' + label + (isMe?' (我)':'') + '</div>' +
      '<div class="h-pbox-info">' +
        (isBuddy && !isMe ? '<span class="h-buddy-tag">队友</span>' : '') +
        (finBadge || ('<span style="color:rgba(255,255,255,.35);font-size:.6rem;">' + (finItem?'':'') + (p?(p.cardCount||0)+'张':'') + '</span>')) +
      '</div>' +
      (cardBacks ? '<div class="h-card-fan">' + cardBacks + '</div>' : '');
  }
}

function render6pCenter(lastPlay, turnSeat) {
  var center  = document.getElementById('hex-center');
  var hintEl  = document.getElementById('hex-hint');
  var trickEl = document.getElementById('hex-trick');
  var leadEl  = document.getElementById('hex-leader-badge');

  if (!lastPlay) {
    trickEl.innerHTML = '';
    leadEl.style.display = (isMyTurn && !hasLastPlay) ? 'block' : 'none';
    hintEl.textContent   = isMyTurn ? (hasLastPlay ? '' : '先出方') : '等待出牌';
  } else {
    leadEl.style.display = 'none';
    var cardsShown = (lastPlay.cards||[]).slice(0, 8);
    var cardsHtml  = cardsShown.map(function(c){ return miniCardHtml(c); }).join('');
    if (lastPlay.cards && lastPlay.cards.length > 8)
      cardsHtml += '<span style="font-size:.6rem;color:rgba(255,255,255,.4);">+' + (lastPlay.cards.length-8) + '</span>';
    trickEl.innerHTML = '<div style="font-size:.62rem;color:rgba(255,255,255,.5);margin-bottom:3px;">' +
      esc(lastPlay.name) + ' · ' + esc(lastPlay.label) + '</div>' +
      '<div style="display:flex;flex-wrap:wrap;justify-content:center;gap:2px;">' + cardsHtml + '</div>';
    hintEl.textContent = isMyTurn ? '需压过此牌' : '';
  }
}

function build6pCardEl(code, idx){
  var key  = code + '_' + idx;
  var isSel = selected.indexOf(key) >= 0;
  var card = document.createElement('div');
  card.className = 'hand-card' + (isSel ? ' selected' : '');
  card.style.width  = '40px';
  card.style.height = '58px';
  card.style.fontSize = '.7rem';
  if (code === 'BJ') {
    card.classList.add('joker-big');
    card.innerHTML = '<div class="joker-label" style="color:#D4AC0D;font-size:.6rem;">大<br>王</div>';
  } else if (code === 'LJ') {
    card.classList.add('joker-small');
    card.innerHTML = '<div class="joker-label" style="color:#666;font-size:.6rem;">小<br>王</div>';
  } else {
    var suit=code[0],rank=code.slice(1);
    var isRed=(suit==='H'||suit==='D');
    card.style.color = isRed?'#C0000F':'#1a1a2e';
    var sym={S:'♠',H:'♥',D:'♦',C:'♣'}[suit];
    var rd=rank==='T'?'10':rank;
    card.innerHTML =
      '<div class="card-top" style="font-size:.65rem;">'+rd+'</div>'+
      '<div class="card-suit" style="font-size:.7rem;">'+sym+'</div>'+
      '<div class="card-center" style="font-size:.85rem;">'+sym+'</div>';
  }
  card.addEventListener('click', (function(c, i){ return function(){ toggleCard6p(c, i); }; })(code, idx));
  return card;
}

/* 六人手牌：同点数竖排成列 */
function render6pHand(hand) {
  var scroll = document.getElementById('hand-scroll-6p');
  scroll.innerHTML = '';
  var curKey = null, colEl = null;
  hand.forEach(function(code, idx) {
    var k = rankKeyOf(code);
    if (k !== curKey) {
      colEl = document.createElement('div');
      colEl.className = 'hand-col';
      scroll.appendChild(colEl);
      curKey = k;
    }
    var card = build6pCardEl(code, idx);
    if (colEl.children.length > 0) card.classList.add('stacked');
    colEl.appendChild(card);
  });
}

function toggleCard6p(code, idx) {
  var key = code + '_' + idx;
  var i   = selected.indexOf(key);
  if (i >= 0) selected.splice(i, 1);
  else         selected.push(key);
  render6pHand(myHand);
  syncButtons6p();
  updateSelInfo6p();
}

function updateSelInfo6p() {
  var n = selected.length;
  document.getElementById('sel-info-6p').textContent    = n > 0 ? '· 已选' + n + '张' : '';
  document.getElementById('sel-info-6p').style.display  = n > 0 ? 'inline' : 'none';
  document.getElementById('btn-cancel-6p').style.display = n > 0 ? 'inline-block' : 'none';
  document.getElementById('btn-play-6p').textContent    = n > 0 ? '出牌(' + n + ')' : '出牌';
}

function syncButtons6p() {
  document.getElementById('btn-play-6p').disabled = !isMyTurn || selected.length === 0;
  document.getElementById('btn-pass-6p').disabled = !isMyTurn || !hasLastPlay;
}
</script>
</body>
</html>
