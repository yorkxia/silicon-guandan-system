<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>密码设置 | Password Settings</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<% const activePage = 'settings'; %>

<div class="admin-wrap">
  <%- include('../partials/admin-sidebar') %>

  <main class="a-main">
    <div class="a-page-head">
      <h1>🔒 密码设置 · Password Settings</h1>
    </div>

    <% if (success && success.length > 0) { %>
      <div class="flash-wrap">
        <% success.forEach(function(m) { %><div class="flash flash-success"><%= m %></div><% }) %>
      </div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="flash-wrap">
        <% error.forEach(function(m) { %><div class="flash flash-error"><%= m %></div><% }) %>
      </div>
    <% } %>

    <div style="max-width:520px">
      <div class="a-card">
        <h2>🔐 修改密码 · Change Password</h2>

        <div style="background:#EBF5FB; border-radius:7px; padding:12px 16px; margin-bottom:20px; font-size:0.85rem; color:#1A5276; border-left:3px solid #2980B9">
          当前账号：<strong><%= user ? user.username : '' %></strong>
          <% if (user && user.is_super_admin) { %>
            <span class="badge badge-super" style="margin-left:6px">超级管理员 · Super Admin</span>
          <% } %>
          <br>
          <em style="font-size:0.78rem; margin-top:3px; display:block">
            修改密码后将自动退出，需重新登录 · After changing password, you'll be logged out automatically
          </em>
        </div>

        <form action="/admin/settings/password" method="POST" id="pwd-form">
          <div class="a-form-group">
            <label for="current_password">当前密码 · Current Password <span class="req">*</span></label>
            <input type="password" id="current_password" name="current_password" class="a-input"
              placeholder="请输入当前密码 · Enter current password" required autocomplete="current-password">
          </div>

          <div class="a-form-group">
            <label for="new_password">新密码 · New Password <span class="req">*</span></label>
            <input type="password" id="new_password" name="new_password" class="a-input"
              placeholder="至少8位，含字母和数字 · Min 8 chars, include letters & numbers"
              required minlength="8" autocomplete="new-password" oninput="checkMatch()">
            <div id="strength-bar" style="margin-top:6px; height:4px; border-radius:2px; background:#EEE; overflow:hidden">
              <div id="strength-fill" style="height:100%; width:0; transition:all 0.3s; border-radius:2px"></div>
            </div>
            <p id="strength-text" class="a-hint"></p>
          </div>

          <div class="a-form-group">
            <label for="confirm_password">确认新密码 · Confirm New Password <span class="req">*</span></label>
            <input type="password" id="confirm_password" name="confirm_password" class="a-input"
              placeholder="再次输入新密码 · Re-enter new password"
              required minlength="8" autocomplete="new-password" oninput="checkMatch()">
            <p id="match-msg" class="a-hint"></p>
          </div>

          <button type="submit" id="submit-btn" class="abtn abtn-primary" style="padding:10px 28px; font-size:0.95rem">
            🔐 确认修改 · Change Password
          </button>
        </form>
      </div>

      <div style="background:#FEF9E7; border-radius:8px; padding:14px 18px; font-size:0.84rem; color:#9A7D0A; border-left:4px solid #D4AC0D">
        <strong>🛡️ 密码安全建议 · Security Tips:</strong>
        <ul style="margin-top:7px; padding-left:18px; line-height:2">
          <li>密码至少8位，建议12位以上 · At least 8 chars, 12+ recommended</li>
          <li>使用大小写字母、数字和符号的组合 · Mix uppercase, lowercase, numbers & symbols</li>
          <li>不要与其他平台使用相同密码 · Don't reuse passwords from other platforms</li>
          <li>所有密码均以 bcrypt 加密存储 · All passwords stored with bcrypt encryption</li>
        </ul>
      </div>
    </div>
  </main>
</div>

<script>
function checkMatch() {
  const np = document.getElementById('new_password').value;
  const cp = document.getElementById('confirm_password').value;
  const msg = document.getElementById('match-msg');
  const btn = document.getElementById('submit-btn');

  // Strength
  const fill = document.getElementById('strength-fill');
  const txt = document.getElementById('strength-text');
  let score = 0;
  if (np.length >= 8) score++;
  if (np.length >= 12) score++;
  if (/[A-Z]/.test(np) && /[a-z]/.test(np)) score++;
  if (/[0-9]/.test(np)) score++;
  if (/[^A-Za-z0-9]/.test(np)) score++;

  const colors = ['', '#E74C3C', '#E67E22', '#F39C12', '#27AE60', '#1E8449'];
  const labels = ['', '弱 Weak', '较弱 Fair', '中等 Medium', '较强 Strong', '强 Very Strong'];
  const widths = ['0%', '20%', '40%', '60%', '80%', '100%'];

  fill.style.width = widths[score] || '0%';
  fill.style.background = colors[score] || '';
  txt.textContent = labels[score] || '';
  txt.style.color = colors[score] || '';

  // Match check
  if (cp.length > 0) {
    if (np === cp) {
      msg.textContent = '✅ 两次密码一致 · Passwords match';
      msg.style.color = '#27AE60';
      btn.disabled = false;
    } else {
      msg.textContent = '❌ 两次密码不一致 · Passwords do not match';
      msg.style.color = '#E74C3C';
      btn.disabled = true;
    }
  } else {
    msg.textContent = '';
    btn.disabled = false;
  }
}
</script>

</body>
</html>
