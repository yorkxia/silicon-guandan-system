<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>管理员登录 | Admin Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="a-login-page">
  <!-- Decorative suits -->
  <div style="position:absolute;top:10%;left:8%;font-size:3rem;color:rgba(212,172,13,0.15);pointer-events:none">♠</div>
  <div style="position:absolute;bottom:12%;right:10%;font-size:4rem;color:rgba(212,172,13,0.1);pointer-events:none">♥</div>
  <div style="position:absolute;top:50%;left:3%;font-size:2rem;color:rgba(212,172,13,0.1);pointer-events:none">♦</div>
  <div style="position:absolute;top:20%;right:5%;font-size:2.5rem;color:rgba(212,172,13,0.1);pointer-events:none">♣</div>

  <div class="a-login-card">
    <div class="a-login-logo">
      <%- include('../partials/logo') %>
      <h2>管理员登录</h2>
      <p>Admin Login · Silicon Valley Guandan League</p>
    </div>

    <% if (error && error.length > 0) { %>
      <div class="flash-wrap">
        <% error.forEach(function(m) { %>
          <div class="flash flash-error"><%= m %></div>
        <% }) %>
      </div>
    <% } %>
    <% if (success && success.length > 0) { %>
      <div class="flash-wrap">
        <% success.forEach(function(m) { %>
          <div class="flash flash-success"><%= m %></div>
        <% }) %>
      </div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="a-form-group">
        <label for="username">用户名 · Username</label>
        <input type="text" id="username" name="username" class="a-input" placeholder="请输入用户名" required autocomplete="username">
      </div>
      <div class="a-form-group">
        <label for="password">密码 · Password</label>
        <input type="password" id="password" name="password" class="a-input" placeholder="请输入密码" required autocomplete="current-password">
      </div>
      <button type="submit" class="btn btn-red btn-full" style="margin-top:6px; font-size:0.97rem; padding:13px;">
        🔐 登录 · Login
      </button>
    </form>

    <div style="margin-top:20px; text-align:center">
      <a href="/" style="font-size:0.82rem; color:#999; text-decoration:none">← 返回网站首页 · Back to Site</a>
    </div>
  </div>
</div>

</body>
</html>
